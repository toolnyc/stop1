---
import Base from '@/layouts/Base.astro';

export interface Props {
  title?: string;
}
const { title = 'Admin — Stop One' } = Astro.props;
---

<Base title={title}>
  <nav class="admin-nav" transition:animate="none">
    <div class="admin-nav-links">
      <a href="/admin" class="admin-nav-link">Events</a>
      <a href="/" class="admin-nav-link admin-nav-back">Back to site</a>
    </div>
    <form method="POST" action="/api/admin/logout" style="display:inline">
      <button type="submit" class="btn btn-secondary btn-sm">Logout</button>
    </form>
  </nav>
  <main class="admin-main">
    <slot />
  </main>
</Base>

<script>
  document.addEventListener('astro:page-load', () => {
    // Auto-loading states for all admin forms with a submit button
    document.querySelectorAll<HTMLFormElement>('.admin-main form').forEach((form) => {
      form.addEventListener('submit', () => {
        const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (btn && !btn.disabled) {
          btn.disabled = true;
          btn.dataset.originalText = btn.textContent || '';
          btn.textContent = btn.textContent?.includes('Save')
            ? 'Saving...'
            : btn.textContent?.includes('Create')
              ? 'Creating...'
              : btn.textContent?.includes('Add')
                ? 'Adding...'
                : btn.textContent?.includes('Archive')
                  ? 'Archiving...'
                  : 'Working...';
        }
      });
    });

    // Loading state for dangerous icon buttons (remove collaborator × etc)
    document.querySelectorAll<HTMLButtonElement>('.btn-icon-remove').forEach((btn) => {
      btn.closest('form')?.addEventListener('submit', () => {
        btn.disabled = true;
        btn.style.opacity = '0.3';
      });
    });
  });
</script>

<style>
  .admin-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-lg);
    border-bottom: var(--border);
    background-color: var(--color-surface);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
  }

  .admin-nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .admin-nav-link {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: var(--weight-medium);
    transition: opacity var(--transition);
  }

  .admin-nav-link:hover {
    opacity: 0.7;
  }

  .admin-nav-back {
    color: var(--color-faint);
  }

  .admin-main {
    padding: var(--space-2xl) var(--space-lg);
    max-width: var(--max-width-admin);
    margin: 0 auto;
    width: 100%;
  }
</style>
