---
import Base from '@/layouts/Base.astro';

export interface Props {
  title?: string;
}
const { title = 'Admin — Stop One' } = Astro.props;
---
<Base title={title}>
  <nav class="admin-nav">
    <a href="/admin" class="admin-nav-brand">Stop One</a>
    <div class="admin-nav-links">
      <a href="/admin">Events</a>
      <form method="POST" action="/api/admin/logout" style="display:inline">
        <button type="submit" class="admin-nav-logout">Logout</button>
      </form>
    </div>
  </nav>
  <main class="admin-main">
    <slot />
  </main>
</Base>

<style>
  .admin-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }

  .admin-nav-brand {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .admin-nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .admin-nav-links a {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .admin-nav-links a:hover {
    color: var(--color-accent);
  }

  .admin-nav-logout {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.875rem;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius);
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .admin-nav-logout:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .admin-main {
    padding: var(--space-6) var(--space-4);
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
  }
</style>
