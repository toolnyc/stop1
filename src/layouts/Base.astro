---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Stop One', description = 'Recurring DIY party series' } = Astro.props;

const typekitId = import.meta.env.PUBLIC_TYPEKIT_KIT_ID;
const hasTypekit = typekitId && typekitId !== 'YOUR_KIT_ID';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a1816" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:image" content="/images/og-logo.png" />
    {hasTypekit && <link rel="stylesheet" href={`https://use.typekit.net/${typekitId}.css`} />}
    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
    <style>
      /* Smooth page transitions */
      ::view-transition-old(main),
      ::view-transition-new(main) {
        animation-duration: 0.4s;
      }
      ::view-transition-old(main) {
        animation-name: fade-out;
      }
      ::view-transition-new(main) {
        animation-name: fade-in;
      }
      @keyframes fade-out {
        from {
          opacity: 1;
        }
        to {
          opacity: 0;
        }
      }
      @keyframes fade-in {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      main {
        view-transition-name: main;
      }
    </style>
  </head>
  <body>
    <slot />
    <script>
      import gsap from 'gsap';

      // Page load animations
      document.addEventListener('astro:page-load', () => {
        // Initial page animations are handled in-page
      });
    </script>
  </body>
</html>
