---
export interface Props {
  slug: string;
  eventTitle: string;
}
const { slug, eventTitle } = Astro.props;
---
<form id="rsvp-form" method="POST" action={`/api/rsvp/${slug}`} class="rsvp-form card">
  <h2 class="rsvp-title">Get on the list</h2>

  <div id="rsvp-message" class="rsvp-message" style="display:none"></div>

  <div id="rsvp-fields" class="rsvp-fields">
    <label>
      <span>Name *</span>
      <input type="text" name="name" required autocomplete="name" placeholder="Your name" />
    </label>

    <label>
      <span>Phone *</span>
      <input type="tel" name="phone" id="rsvp-phone" required autocomplete="tel" placeholder="(555) 123-4567" />
    </label>

    <label>
      <span>Email</span>
      <input type="email" name="email" autocomplete="email" placeholder="Optional — for email updates" />
    </label>

    <label class="sms-label">
      <div class="checkbox-row">
        <input type="checkbox" name="sms_opt_in" value="true" checked />
        <span class="checkbox-text">Text me event reminders</span>
      </div>
    </label>

    <button type="submit" id="rsvp-submit" class="btn btn-primary btn-block">RSVP</button>
  </div>
</form>

<script>
  const form = document.getElementById('rsvp-form') as HTMLFormElement;
  const fields = document.getElementById('rsvp-fields')!;
  const message = document.getElementById('rsvp-message')!;
  const submitBtn = document.getElementById('rsvp-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = {
      name: formData.get('name') as string,
      phone: (formData.get('phone') as string) || '',
      email: (formData.get('email') as string) || '',
      sms_opt_in: formData.get('sms_opt_in') === 'true',
    };

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        fields.style.display = 'none';
        message.className = 'rsvp-message alert alert-success';
        message.innerHTML = `<strong>You're on the list, ${data.name}!</strong><br><span class="confirm-sub">Check your texts for confirmation.</span>`;
        message.style.display = 'block';
      } else {
        message.className = 'rsvp-message alert alert-error';
        message.textContent = result.error || 'Something went wrong';
        message.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'RSVP';
      }
    } catch {
      message.className = 'rsvp-message alert alert-error';
      message.textContent = 'Network error. Please try again.';
      message.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'RSVP';
    }
  });
</script>

<style>
  .rsvp-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .rsvp-title {
    font-size: 1.125rem;
    font-weight: var(--weight-bold);
  }

  .rsvp-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .checkbox-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-direction: row;
  }

  .checkbox-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-accent);
  }

  .checkbox-text {
    font-size: 0.875rem !important;
    color: var(--color-fg) !important;
    font-weight: var(--weight-regular) !important;
    text-transform: none !important;
    letter-spacing: normal !important;
  }

  .rsvp-message {
    text-align: center;
  }

  .confirm-sub {
    font-size: 0.8125rem;
    opacity: 0.8;
  }
</style>
