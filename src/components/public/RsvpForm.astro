---
export interface Props {
  slug: string;
  eventTitle: string;
}
const { slug, eventTitle } = Astro.props;
---
<form id="rsvp-form" method="POST" action={`/api/rsvp/${slug}`} class="rsvp-form">
  <h2>RSVP</h2>

  <div id="rsvp-message" class="rsvp-message" style="display:none"></div>

  <div id="rsvp-fields">
    <label>
      <span>Name *</span>
      <input type="text" name="name" required />
    </label>

    <label>
      <span>Email *</span>
      <input type="email" name="email" required />
    </label>

    <label>
      <span>Phone</span>
      <input type="tel" name="phone" id="rsvp-phone" />
    </label>

    <label id="sms-opt-in-label" style="display:none">
      <div class="checkbox-row">
        <input type="checkbox" name="sms_opt_in" value="true" />
        <span>Send me SMS reminders</span>
      </div>
    </label>

    <button type="submit" id="rsvp-submit">RSVP</button>
  </div>
</form>

<script>
  const form = document.getElementById('rsvp-form') as HTMLFormElement;
  const fields = document.getElementById('rsvp-fields')!;
  const message = document.getElementById('rsvp-message')!;
  const phone = document.getElementById('rsvp-phone') as HTMLInputElement;
  const smsLabel = document.getElementById('sms-opt-in-label')!;
  const submitBtn = document.getElementById('rsvp-submit') as HTMLButtonElement;

  phone?.addEventListener('input', () => {
    smsLabel.style.display = phone.value.trim() ? 'block' : 'none';
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = {
      name: formData.get('name') as string,
      email: formData.get('email') as string,
      phone: (formData.get('phone') as string) || '',
      sms_opt_in: formData.get('sms_opt_in') === 'true',
    };

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        fields.style.display = 'none';
        message.className = 'rsvp-message success';
        message.textContent = `You're on the list, ${data.name}!`;
        message.style.display = 'block';
      } else {
        message.className = 'rsvp-message error';
        message.textContent = result.error || 'Something went wrong';
        message.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'RSVP';
      }
    } catch {
      message.className = 'rsvp-message error';
      message.textContent = 'Network error. Please try again.';
      message.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'RSVP';
    }
  });
</script>

<style>
  .rsvp-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .rsvp-form h2 {
    font-size: 1.25rem;
    color: var(--color-accent);
  }

  #rsvp-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  label span {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"] {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 1rem;
  }

  input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .checkbox-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-direction: row;
  }

  .checkbox-row input[type="checkbox"] {
    width: auto;
  }

  button {
    width: 100%;
    padding: var(--space-3);
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
  }

  button:hover { opacity: 0.9; }
  button:disabled { opacity: 0.5; cursor: not-allowed; }

  .rsvp-message {
    padding: var(--space-3);
    border-radius: var(--radius);
    font-size: 0.9375rem;
    text-align: center;
  }

  .rsvp-message.success {
    background: color-mix(in srgb, var(--color-success) 15%, transparent);
    border: 1px solid var(--color-success);
    color: var(--color-success);
  }

  .rsvp-message.error {
    background: color-mix(in srgb, var(--color-error) 15%, transparent);
    border: 1px solid var(--color-error);
    color: var(--color-error);
  }
</style>
