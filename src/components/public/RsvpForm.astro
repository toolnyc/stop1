---
export interface Props {
  slug: string;
  eventTitle: string;
}
const { slug, eventTitle } = Astro.props;
---

<form id="rsvp-form" method="POST" action={`/api/rsvp/${slug}`} class="rsvp-form">
  <h2 class="rsvp-title">RSVP</h2>

  <div id="rsvp-message" class="rsvp-message" style="display:none"></div>

  <div id="rsvp-fields" class="rsvp-fields">
    <label>
      <span>Name</span>
      <input type="text" name="name" required autocomplete="name" placeholder="Your name" />
    </label>

    <label>
      <span>Phone</span>
      <input
        type="tel"
        name="phone"
        id="rsvp-phone"
        required
        autocomplete="tel"
        placeholder="(555) 123-4567"
      />
    </label>

    <label>
      <span>Email</span>
      <input
        type="email"
        name="email"
        autocomplete="email"
        placeholder="Optional — for email updates"
      />
    </label>

    <label class="sms-label">
      <div class="checkbox-row">
        <input type="checkbox" name="sms_opt_in" value="true" checked />
        <span class="checkbox-text">Text me event reminders</span>
      </div>
    </label>

    <button type="submit" id="rsvp-submit" class="btn btn-primary btn-block">Submit</button>
  </div>
</form>

<script>
  import gsap from 'gsap';

  const form = document.getElementById('rsvp-form') as HTMLFormElement;
  const fields = document.getElementById('rsvp-fields')!;
  const message = document.getElementById('rsvp-message')!;
  const submitBtn = document.getElementById('rsvp-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = {
      name: formData.get('name') as string,
      phone: (formData.get('phone') as string) || '',
      email: (formData.get('email') as string) || '',
      sms_opt_in: formData.get('sms_opt_in') === 'true',
    };

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        // Animate form out
        gsap.to(fields, {
          duration: 0.4,
          opacity: 0,
          y: -20,
          ease: 'power2.in',
          onComplete: () => {
            fields.style.display = 'none';
            message.className = 'rsvp-message success-message';
            message.innerHTML = `
              <div class="success-check">✓</div>
              <div class="success-text">You're on the list, ${data.name}!</div>
              <div class="success-sub">Check your texts for confirmation.</div>
            `;
            message.style.display = 'block';

            // Animate success in
            gsap.from('.success-check', {
              duration: 0.6,
              scale: 0,
              rotation: -180,
              ease: 'back.out(1.7)',
            });
            gsap.from('.success-text', {
              duration: 0.6,
              opacity: 0,
              y: 20,
              delay: 0.2,
              ease: 'power3.out',
            });
            gsap.from('.success-sub', {
              duration: 0.6,
              opacity: 0,
              y: 20,
              delay: 0.3,
              ease: 'power3.out',
            });
          },
        });
      } else {
        message.className = 'rsvp-message alert alert-error';
        message.textContent = result.error || 'Something went wrong';
        message.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit';
      }
    } catch {
      message.className = 'rsvp-message alert alert-error';
      message.textContent = 'Network error. Please try again.';
      message.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit';
    }
  });
</script>

<style>
  .rsvp-form {
    background: var(--color-surface);
    border: var(--border);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .rsvp-title {
    font-size: 1.125rem;
    font-weight: var(--weight-bold);
  }

  .rsvp-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .checkbox-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-direction: row;
  }

  .checkbox-row input[type='checkbox'] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-fg);
  }

  .checkbox-text {
    font-size: 0.875rem;
    color: var(--color-fg);
    font-weight: var(--weight-regular);
    letter-spacing: normal;
  }

  .rsvp-message {
    text-align: center;
  }

  .success-message {
    padding: var(--space-xl) 0;
  }

  .success-check {
    font-size: 3rem;
    margin-bottom: var(--space-md);
  }

  .success-text {
    font-size: 1.25rem;
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-sm);
  }

  .success-sub {
    font-size: 0.875rem;
    color: var(--color-muted);
  }
</style>
