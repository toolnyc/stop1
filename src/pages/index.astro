---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';

// Get next upcoming published event
const { data: events } = await supabase
  .from('events')
  .select('title, slug, date')
  .eq('status', 'published')
  .gte('date', new Date().toISOString())
  .order('date', { ascending: true })
  .limit(1);

const nextEvent = events?.[0] ?? null;
const eventDate = nextEvent ? new Date(nextEvent.date) : null;
---
<Base title="Stop One">
  <main class="landing" data-event-slug={nextEvent?.slug}>
    <div class="landing-content">
      <img src="/images/wordmark.svg" alt="Stop One" class="wordmark" />

      {eventDate ? (
        <div class="countdown mono" data-target={eventDate.toISOString()}>
          <span class="countdown-label">IN</span>
          <span class="countdown-value" id="countdown-days">0</span><span class="countdown-unit">D</span>
          <span class="countdown-value" id="countdown-hours">0</span><span class="countdown-unit">H</span>
          <span class="countdown-value" id="countdown-mins">0</span><span class="countdown-unit">M</span>
        </div>
      ) : (
        <div class="countdown mono">
          <span class="countdown-tba">NEXT EVENT TBA</span>
        </div>
      )}

      {nextEvent ? (
        <a href={`/events/${nextEvent.slug}`} class="rsvp-link" id="rsvp-btn">
          <span class="rsvp-text">RSVP</span>
        </a>
      ) : null}
    </div>
  </main>
</Base>

<script>
  import gsap from 'gsap';

  // Countdown timer
  const countdownEl = document.querySelector('.countdown');
  if (countdownEl && countdownEl.hasAttribute('data-target')) {
    const target = new Date(countdownEl.getAttribute('data-target')!);
    const daysEl = document.getElementById('countdown-days');
    const hoursEl = document.getElementById('countdown-hours');
    const minsEl = document.getElementById('countdown-mins');

    function updateCountdown() {
      const now = new Date();
      const diff = target.getTime() - now.getTime();

      if (diff <= 0) {
        if (daysEl) daysEl.textContent = '0';
        if (hoursEl) hoursEl.textContent = '0';
        if (minsEl) minsEl.textContent = '0';
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

      if (daysEl) daysEl.textContent = String(days);
      if (hoursEl) hoursEl.textContent = String(hours);
      if (minsEl) minsEl.textContent = String(mins);
    }

    updateCountdown();
    setInterval(updateCountdown, 60000);
  }

  // RSVP hover animation
  const rsvpBtn = document.getElementById('rsvp-btn');
  if (rsvpBtn) {
    const textEl = rsvpBtn.querySelector('.rsvp-text');
    if (textEl) {
      const originalText = 'RSVP';
      const hoverText = 'RESERVE YOUR PLAY';

      rsvpBtn.addEventListener('mouseenter', () => {
        gsap.to(textEl, {
          duration: 0.3,
          ease: 'power2.out',
          onStart: () => {
            textEl.textContent = hoverText;
          }
        });
        gsap.fromTo(textEl,
          { letterSpacing: '0.1em' },
          { duration: 0.4, ease: 'power2.out', letterSpacing: '0.3em' }
        );
      });

      rsvpBtn.addEventListener('mouseleave', () => {
        gsap.to(textEl, {
          duration: 0.2,
          ease: 'power2.in',
          onComplete: () => {
            textEl.textContent = originalText;
          }
        });
        gsap.to(textEl, {
          duration: 0.2,
          ease: 'power2.in',
          letterSpacing: '0.1em'
        });
      });
    }
  }

  // Entrance animation
  gsap.from('.wordmark', {
    duration: 0.8,
    opacity: 0,
    y: -20,
    ease: 'power3.out'
  });
  gsap.from('.countdown', {
    duration: 0.8,
    opacity: 0,
    y: 20,
    delay: 0.2,
    ease: 'power3.out'
  });
  gsap.from('.rsvp-link', {
    duration: 0.8,
    opacity: 0,
    y: 20,
    delay: 0.4,
    ease: 'power3.out'
  });
</script>

<style>
  .landing {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
  }

  .landing-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    text-align: center;
  }

  .wordmark {
    height: 3rem;
    width: auto;
  }

  .countdown {
    font-size: 1.125rem;
    font-weight: var(--weight-medium);
    letter-spacing: 0.15em;
  }

  .countdown-label {
    margin-right: 0.5em;
  }

  .countdown-value {
    font-weight: var(--weight-bold);
  }

  .countdown-unit {
    margin-right: 0.5em;
    opacity: 0.6;
  }

  .countdown-tba {
    opacity: 0.5;
  }

  .rsvp-link {
    font-size: 1.5rem;
    font-weight: var(--weight-bold);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: opacity var(--transition);
  }

  .rsvp-link:hover {
    opacity: 0.7;
  }

  .rsvp-text {
    display: inline-block;
  }
</style>
