---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { EVENT_TIMEZONE } from '@/lib/constants';

// Get next upcoming published event (stay visible until 12 hours after end time)
const now = new Date();
const cutoff = new Date(now.getTime() - 12 * 60 * 60 * 1000).toISOString();
const { data: events } = await supabase
  .from('events')
  .select(
    'title, slug, date, time_end, flyer_url, venue_name, venue_address, description, door_price, early_price, early_cutoff',
  )
  .eq('status', 'published')
  .or(`time_end.gte.${cutoff},and(time_end.is.null,date.gte.${cutoff})`)
  .order('date', { ascending: true })
  .limit(1);

const nextEvent = events?.[0] ?? null;
const eventDate = nextEvent ? new Date(nextEvent.date) : null;

const formatTime = (date: Date) => {
  return date
    .toLocaleTimeString('en-US', {
      hour: 'numeric',
      minute: '2-digit',
      hour12: true,
      timeZone: EVENT_TIMEZONE,
    })
    .toLowerCase()
    .replace(':00', '')
    .replace(' ', '');
};

// Format event details for the info modal
const dateFormatted = eventDate
  ? eventDate.toLocaleDateString('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      timeZone: EVENT_TIMEZONE,
    })
  : null;

const timeFormatted = eventDate ? formatTime(eventDate) : null;
const timeEnd = nextEvent?.time_end ? formatTime(new Date(nextEvent.time_end)) : null;

const formatPrice = (price: number) => (price === 0 ? 'free' : `$${Math.floor(price)}`);

const hasEarlyPricing =
  nextEvent?.early_price !== null &&
  nextEvent?.early_price !== undefined &&
  nextEvent?.early_cutoff;

const earlyPriceFormatted = hasEarlyPricing ? formatPrice(nextEvent.early_price!) : null;
const earlyTimeFormatted = hasEarlyPricing ? formatTime(new Date(nextEvent.early_cutoff!)) : null;
const doorPriceFormatted =
  nextEvent?.door_price !== null && nextEvent?.door_price !== undefined
    ? formatPrice(nextEvent.door_price)
    : null;
---

<Base title="Stop One">
  <main class="landing">
    <div class="landing-content">
      {
        nextEvent?.flyer_url ? (
          <div class="flyer-scene" id="flyer-scene">
            <div class="flyer-card" id="flyer-card">
              <div class="flyer-shine" id="flyer-shine" />
              <img
                src={nextEvent.flyer_url}
                alt={`${nextEvent.title} flyer`}
                class="flyer-img"
                loading="eager"
                draggable="false"
              />
            </div>
          </div>
        ) : (
          <img src="/images/wordmark.svg" alt="Stop One" class="wordmark" />
        )
      }

      {
        nextEvent ? (
          <div class="actions">
            <a href={`/events/${nextEvent.slug}`} class="action-btn">
              RSVP
            </a>
            <button
              type="button"
              class="action-btn action-btn--here"
              id="here-btn"
              data-slug={nextEvent.slug}
              data-door-price={nextEvent.door_price ?? 0}
              data-early-price={nextEvent.early_price ?? ''}
              data-early-cutoff={nextEvent.early_cutoff ?? ''}
            >
              I'm here
            </button>
            <button type="button" class="action-btn" id="info-btn">
              Info
            </button>
          </div>
        ) : null
      }
    </div>

    <footer class="landing-footer dark-ctx" id="footer-bar">
      <div class="footer-slot" id="footer-slot">
        <span class="footer-item footer-text" data-idx="0">your first</span>
        <span class="footer-item footer-text" data-idx="1">your last</span>
        <span class="footer-item footer-text" data-idx="2">your only</span>
        <img
          class="footer-item footer-logo"
          data-idx="3"
          src="/images/wordmark.svg"
          alt="Stop One"
        />
      </div>
    </footer>

    {/* Info modal */}
    {
      nextEvent && (
        <div class="modal-backdrop" id="info-modal" aria-hidden="true">
          <div class="modal-sheet" role="dialog" aria-label="Event info">
            <button type="button" class="modal-close" id="modal-close" aria-label="Close">
              &times;
            </button>
            <div class="modal-body">
              <h2 class="modal-title">{nextEvent.title}</h2>

              <dl class="info-list">
                {dateFormatted && (
                  <div class="info-row">
                    <dt class="info-label">Date</dt>
                    <dd class="info-value">{dateFormatted}</dd>
                  </div>
                )}

                {timeFormatted && (
                  <div class="info-row">
                    <dt class="info-label">Time</dt>
                    <dd class="info-value">
                      {timeFormatted}
                      {timeEnd ? `\u2013${timeEnd}` : ''}
                    </dd>
                  </div>
                )}

                {(doorPriceFormatted || earlyPriceFormatted) && (
                  <div class="info-row">
                    <dt class="info-label">Price</dt>
                    <dd class="info-value">
                      {hasEarlyPricing ? (
                        <span>
                          {earlyPriceFormatted} before {earlyTimeFormatted} &middot;{' '}
                          {doorPriceFormatted} after
                        </span>
                      ) : (
                        doorPriceFormatted
                      )}
                    </dd>
                  </div>
                )}

                {nextEvent.venue_name && (
                  <div class="info-row">
                    <dt class="info-label">Location</dt>
                    <dd class="info-value">
                      {nextEvent.venue_name}
                      {nextEvent.venue_address && (
                        <span class="info-sub">{nextEvent.venue_address}</span>
                      )}
                    </dd>
                  </div>
                )}
              </dl>

              {nextEvent.description && <p class="modal-desc">{nextEvent.description}</p>}
            </div>
          </div>
        </div>
      )
    }

    {/* Self-check-in overlay */}
    {
      nextEvent && (
        <div class="ci-backdrop" id="ci-modal" aria-hidden="true">
          <div class="ci-sheet" id="ci-sheet" role="dialog" aria-label="Check in">
            <div class="ci-header">
              <span class="ci-title">find your name</span>
              <button type="button" class="ci-close" id="ci-close" aria-label="Close">
                &times;
              </button>
            </div>

            {/* Step 1: Search */}
            <div class="ci-step" id="ci-step-search">
              <div class="ci-search-wrap">
                <input
                  type="text"
                  id="ci-search"
                  placeholder="Search your name..."
                  autocomplete="off"
                  class="ci-search"
                />
              </div>
              <ul class="ci-results" id="ci-results" />
              <div class="ci-walkin-wrap">
                <button type="button" class="ci-walkin-btn" id="ci-walkin-btn">
                  I am a walk-in
                </button>
              </div>
            </div>

            {/* Step 2: Walk-in info */}
            <div class="ci-step" id="ci-step-walkin" style="display:none">
              <div class="ci-walkin-form">
                <h2 class="ci-walkin-heading">walk-in</h2>
                <input
                  type="text"
                  id="ci-walkin-name"
                  placeholder="Name"
                  autocomplete="name"
                  class="ci-search"
                  enterkeyhint="next"
                />
                <input
                  type="tel"
                  id="ci-walkin-phone"
                  placeholder="Phone (optional)"
                  autocomplete="tel"
                  class="ci-search"
                  enterkeyhint="next"
                />
                <input
                  type="email"
                  id="ci-walkin-email"
                  placeholder="Email (optional)"
                  autocomplete="email"
                  class="ci-search"
                  enterkeyhint="done"
                />
                <button
                  type="button"
                  class="btn btn-primary btn-block ci-walkin-submit"
                  id="ci-walkin-submit"
                  disabled
                >
                  Continue
                </button>
              </div>
            </div>

            {/* Step 3: Payment */}
            <div class="ci-step" id="ci-step-pay" style="display:none">
              <h2 class="ci-selected-name" id="ci-selected-name" />
              <p class="ci-price" id="ci-price" />
              <div class="ci-pay-buttons" id="ci-pay-buttons">
                <button type="button" class="btn ci-btn-pay" id="ci-btn-cash">
                  <span class="ci-pay-icon">$</span>
                  Cash
                </button>
                <button type="button" class="btn ci-btn-pay" id="ci-btn-card">
                  <span class="ci-pay-icon">&#9909;</span>
                  Card
                </button>
              </div>
              <div class="ci-processing" id="ci-processing" style="display:none">
                <div class="ci-spinner" />
                <p>Processing...</p>
              </div>
              <p class="ci-error" id="ci-error" style="display:none" />
            </div>
          </div>
        </div>
      )
    }

    {/* Menu overlay with login */}
    <div class="menu-overlay" id="menu-overlay" aria-hidden="true">
      <button type="button" class="menu-close" id="menu-close" aria-label="Close">&times;</button>
      <div class="menu-content">
        <form method="POST" action="/api/admin/login" class="menu-login">
          <label>
            <span>Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
            />
          </label>
          <label>
            <span>Password</span>
            <input type="password" name="password" required autocomplete="current-password" />
          </label>
          <button type="submit" class="btn btn-primary btn-block">Sign in</button>
        </form>
      </div>
    </div>
  </main>
</Base>

<script>
  import gsap from 'gsap';

  // Module-level state so cleanup works across navigations
  let _rafId: number | null = null;
  let _handleOrientation: ((e: DeviceOrientationEvent) => void) | null = null;
  let _phraseInterval: ReturnType<typeof setInterval> | null = null;
  let _ciDebounce: ReturnType<typeof setTimeout> | null = null;

  function cleanup() {
    if (_rafId) {
      cancelAnimationFrame(_rafId);
      _rafId = null;
    }
    if (_handleOrientation) {
      window.removeEventListener('deviceorientation', _handleOrientation);
      _handleOrientation = null;
    }
    if (_phraseInterval) {
      clearInterval(_phraseInterval);
      _phraseInterval = null;
    }
    if (_ciDebounce) {
      clearTimeout(_ciDebounce);
      _ciDebounce = null;
    }
  }

  document.addEventListener('astro:before-swap', cleanup);

  document.addEventListener('astro:page-load', () => {
    cleanup();
    gsap.killTweensOf(
      '.flyer-card, .wordmark, .actions, .landing-footer, .modal-backdrop, .modal-sheet, .menu-overlay, .menu-content, .footer-text, .footer-logo, .ci-backdrop, .ci-sheet',
    );

    // Reset GSAP-animated elements to clean state (targeted, not nuclear)
    const gsapTargets =
      '.flyer-card, .wordmark, .actions, .landing-footer, .modal-backdrop, .modal-sheet, .menu-overlay, .menu-content, .footer-item, .ci-backdrop, .ci-sheet';
    document.querySelectorAll<HTMLElement>(gsapTargets).forEach((el) => {
      if (el.style.length > 0) el.removeAttribute('style');
    });

    // Re-apply the initial display:none states that the server renders
    const hiddenByDefault = ['#info-modal', '#menu-overlay', '#ci-modal'];
    hiddenByDefault.forEach((sel) => {
      const el = document.querySelector<HTMLElement>(sel);
      if (el) {
        el.setAttribute('aria-hidden', 'true');
        el.style.display = 'none';
      }
    });

    // Footer items: show first, hide rest
    document.querySelectorAll<HTMLElement>('.footer-item').forEach((el, i) => {
      el.style.display = i === 0 ? 'block' : 'none';
      el.style.opacity = i === 0 ? '1' : '0';
    });

    // Grab refs we need below
    const card = document.getElementById('flyer-card');
    const shine = document.getElementById('flyer-shine');
    const modal = document.getElementById('info-modal');
    const modalSheet = modal?.querySelector('.modal-sheet') as HTMLElement | null;
    const menuOverlay = document.getElementById('menu-overlay');
    const menuContent = menuOverlay?.querySelector('.menu-content') as HTMLElement | null;

    // --- Interactive flyer card ---
    const scene = document.getElementById('flyer-scene');

    if (scene && card && shine) {
      const MAX_TILT = 6;
      let gyroActive = false;
      let currentRotateX = 0;
      let currentRotateY = 0;
      let targetRotateX = 0;
      let targetRotateY = 0;

      function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
      }

      function updateCard() {
        currentRotateX = lerp(currentRotateX, targetRotateX, 0.05);
        currentRotateY = lerp(currentRotateY, targetRotateY, 0.05);

        card.style.transform = `perspective(1200px) rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg)`;

        const shineX = 50 + (currentRotateY / MAX_TILT) * 40;
        const shineY = 50 - (currentRotateX / MAX_TILT) * 40;
        shine.style.background = `radial-gradient(circle at ${shineX}% ${shineY}%, rgba(255,255,255,0.08) 0%, transparent 80%)`;

        _rafId = requestAnimationFrame(updateCard);
      }

      _rafId = requestAnimationFrame(updateCard);

      function handleOrientation(e: DeviceOrientationEvent) {
        if (e.gamma === null || e.beta === null) return;
        gyroActive = true;
        targetRotateY = Math.max(-MAX_TILT, Math.min(MAX_TILT, e.gamma * 0.4));
        targetRotateX = Math.max(-MAX_TILT, Math.min(MAX_TILT, (e.beta - 45) * -0.3));
      }
      _handleOrientation = handleOrientation;

      if (
        typeof DeviceOrientationEvent !== 'undefined' &&
        typeof (DeviceOrientationEvent as unknown as { requestPermission?: () => Promise<string> })
          .requestPermission === 'function'
      ) {
        scene.addEventListener(
          'click',
          async () => {
            if (gyroActive) return;
            try {
              const permission = await (
                DeviceOrientationEvent as unknown as { requestPermission: () => Promise<string> }
              ).requestPermission();
              if (permission === 'granted') {
                window.addEventListener('deviceorientation', handleOrientation);
              }
            } catch {
              /* user denied */
            }
          },
          { once: true },
        );
      } else {
        window.addEventListener('deviceorientation', handleOrientation);
      }

      scene.addEventListener(
        'touchmove',
        (e) => {
          if (gyroActive) return;
          const touch = e.touches[0];
          const rect = scene.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const x = (touch.clientX - centerX) / (rect.width / 2);
          const y = (touch.clientY - centerY) / (rect.height / 2);
          targetRotateY = x * MAX_TILT;
          targetRotateX = -y * MAX_TILT;
        },
        { passive: true },
      );

      scene.addEventListener('touchend', () => {
        if (gyroActive) return;
        targetRotateX = 0;
        targetRotateY = 0;
      });

      scene.addEventListener('mousemove', (e) => {
        const rect = scene.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const x = (e.clientX - centerX) / (rect.width / 2);
        const y = (e.clientY - centerY) / (rect.height / 2);
        targetRotateY = x * MAX_TILT;
        targetRotateX = -y * MAX_TILT;
      });

      scene.addEventListener('mouseleave', () => {
        targetRotateX = 0;
        targetRotateY = 0;
      });
    }

    // --- Footer rotation: text phrases + wordmark as peers ---
    const footerItems = document.querySelectorAll<HTMLElement>('.footer-item');
    if (footerItems.length > 0) {
      let activeIdx = 0;

      function rotateFooter() {
        const current = footerItems[activeIdx];
        const nextIdx = (activeIdx + 1) % footerItems.length;
        const next = footerItems[nextIdx];

        gsap.to(current, {
          duration: 0.3,
          opacity: 0,
          y: -10,
          ease: 'power2.in',
          onComplete: () => {
            current.style.display = 'none';
            next.style.display = 'block';
            gsap.fromTo(
              next,
              { opacity: 0, y: 10 },
              { duration: 0.3, opacity: 1, y: 0, ease: 'power2.out' },
            );
            activeIdx = nextIdx;
          },
        });
      }

      _phraseInterval = setInterval(rotateFooter, 2200);
    }

    // --- Info modal ---
    const infoBtn = document.getElementById('info-btn');
    const modalClose = document.getElementById('modal-close');

    if (infoBtn && modal && modalClose && modalSheet) {
      function openModal() {
        modal.setAttribute('aria-hidden', 'false');
        modal.style.display = 'flex';
        gsap.fromTo(modal, { opacity: 0 }, { duration: 0.25, opacity: 1, ease: 'power2.out' });
        gsap.fromTo(
          modalSheet,
          { y: 40, opacity: 0 },
          { duration: 0.35, y: 0, opacity: 1, ease: 'power3.out', delay: 0.05 },
        );
      }

      function closeModal() {
        gsap.to(modal, {
          duration: 0.2,
          opacity: 0,
          ease: 'power2.in',
          onComplete: () => {
            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
          },
        });
      }

      infoBtn.addEventListener('click', openModal);
      modalClose.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
      });
    }

    // --- Self-check-in overlay ---
    const hereBtn = document.getElementById('here-btn') as HTMLButtonElement | null;
    const ciModal = document.getElementById('ci-modal');
    const ciSheet = document.getElementById('ci-sheet');
    const ciClose = document.getElementById('ci-close');
    const ciSearch = document.getElementById('ci-search') as HTMLInputElement | null;
    const ciResults = document.getElementById('ci-results');
    const ciStepSearch = document.getElementById('ci-step-search');
    const ciStepWalkin = document.getElementById('ci-step-walkin');
    const ciStepPay = document.getElementById('ci-step-pay');
    const ciSelectedName = document.getElementById('ci-selected-name');
    const ciPrice = document.getElementById('ci-price');
    const ciPayButtons = document.getElementById('ci-pay-buttons');
    const ciProcessing = document.getElementById('ci-processing');
    const ciError = document.getElementById('ci-error');
    const ciSlug = hereBtn?.dataset.slug ?? '';

    // Walk-in form elements
    const ciWalkinBtn = document.getElementById('ci-walkin-btn');
    const ciWalkinName = document.getElementById('ci-walkin-name') as HTMLInputElement | null;
    const ciWalkinPhone = document.getElementById('ci-walkin-phone') as HTMLInputElement | null;
    const ciWalkinEmail = document.getElementById('ci-walkin-email') as HTMLInputElement | null;
    const ciWalkinSubmit = document.getElementById('ci-walkin-submit') as HTMLButtonElement | null;

    let _ciSelectedRsvpId = '';
    let _ciIsWalkin = false;

    const _simulatePaid = new URLSearchParams(window.location.search).get('simulate') === 'paid';

    function getEffectivePrice(): number {
      if (!hereBtn) return 0;
      const doorPrice = Number(hereBtn.dataset.doorPrice) || 0;
      if (_simulatePaid) return doorPrice || 10;
      const earlyPrice = hereBtn.dataset.earlyPrice;
      const earlyCutoff = hereBtn.dataset.earlyCutoff;
      if (earlyPrice && earlyCutoff && new Date() < new Date(earlyCutoff)) {
        return Number(earlyPrice);
      }
      return doorPrice;
    }

    function esc(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function openCheckin() {
      if (!ciModal || !ciSheet) return;
      // Reset state
      if (ciSearch) ciSearch.value = '';
      if (ciResults) ciResults.innerHTML = '';
      if (ciStepSearch) ciStepSearch.style.display = 'flex';
      if (ciStepWalkin) ciStepWalkin.style.display = 'none';
      if (ciStepPay) ciStepPay.style.display = 'none';
      if (ciWalkinName) ciWalkinName.value = '';
      if (ciWalkinPhone) ciWalkinPhone.value = '';
      if (ciWalkinEmail) ciWalkinEmail.value = '';
      if (ciWalkinSubmit) ciWalkinSubmit.disabled = true;
      _ciIsWalkin = false;
      if (ciError) ciError.style.display = 'none';
      _ciSelectedRsvpId = '';

      ciModal.setAttribute('aria-hidden', 'false');
      ciModal.style.display = 'flex';
      gsap.fromTo(ciModal, { opacity: 0 }, { duration: 0.25, opacity: 1, ease: 'power2.out' });
      gsap.fromTo(
        ciSheet,
        { y: '100%' },
        { duration: 0.4, y: '0%', ease: 'power3.out', delay: 0.05 },
      );
      setTimeout(() => ciSearch?.focus(), 300);
    }

    function closeCheckin() {
      if (!ciModal || !ciSheet) return;
      gsap.to(ciSheet, { y: '100%', duration: 0.35, ease: 'power2.in' });
      gsap.to(ciModal, {
        opacity: 0,
        duration: 0.25,
        delay: 0.1,
        ease: 'power2.in',
        onComplete: () => {
          ciModal.style.display = 'none';
          ciModal.setAttribute('aria-hidden', 'true');
        },
      });
    }

    async function doCheckinSearch() {
      if (!ciSearch || !ciResults) return;
      const q = ciSearch.value.trim();
      if (!q) {
        ciResults.innerHTML = '';
        return;
      }
      try {
        const res = await fetch(`/api/checkin/${ciSlug}/search?q=${encodeURIComponent(q)}`);
        if (!res.ok) return;
        const guests = (await res.json()) as { id: string; name: string }[];
        if (guests.length === 0) {
          ciResults.innerHTML = '<li class="ci-empty">No matches found</li>';
          return;
        }
        ciResults.innerHTML = guests
          .map(
            (g) =>
              `<li class="ci-result-item" data-id="${esc(g.id)}" data-name="${esc(g.name)}">${esc(g.name)}</li>`,
          )
          .join('');
      } catch {
        ciResults.innerHTML = '<li class="ci-empty">Search failed</li>';
      }
    }

    function selectGuest(id: string, name: string) {
      _ciSelectedRsvpId = id;
      const price = getEffectivePrice();

      if (price === 0) {
        // Free event: skip payment, check in directly
        doFreeCashCheckin(id);
        return;
      }

      // Show payment step
      if (ciSelectedName) ciSelectedName.textContent = name;
      if (ciPrice) ciPrice.textContent = `$${price.toFixed(0)}`;
      if (ciStepSearch) ciStepSearch.style.display = 'none';
      if (ciStepPay) ciStepPay.style.display = 'flex';
      if (ciPayButtons) ciPayButtons.style.display = 'flex';
      if (ciProcessing) ciProcessing.style.display = 'none';
      if (ciError) ciError.style.display = 'none';
    }

    function _ciBody(extra: Record<string, unknown>) {
      if (_simulatePaid) extra.simulate = 'paid';
      return JSON.stringify(extra);
    }

    async function doFreeCashCheckin(rsvpId: string) {
      showCiProcessing();
      try {
        const res = await fetch(`/api/checkin/${ciSlug}/cash`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: _ciBody({ rsvpId }),
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Check-in failed');
        }
        window.location.href = `/checkin/${ciSlug}/confirmed?rsvp_id=${rsvpId}&method=free`;
      } catch (err) {
        showCiError((err as Error).message || 'Something went wrong');
      }
    }

    async function doCashCheckin() {
      showCiProcessing();
      try {
        const res = await fetch(`/api/checkin/${ciSlug}/cash`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: _ciBody({ rsvpId: _ciSelectedRsvpId }),
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Check-in failed');
        }
        window.location.href = `/checkin/${ciSlug}/confirmed?rsvp_id=${_ciSelectedRsvpId}&method=cash`;
      } catch (err) {
        showCiError((err as Error).message || 'Something went wrong');
      }
    }

    async function doCardCheckin() {
      showCiProcessing();
      try {
        const res = await fetch(`/api/checkin/${ciSlug}/create-checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: _ciBody({ rsvpId: _ciSelectedRsvpId }),
        });
        const data = await res.json();
        if (!res.ok) {
          throw new Error(data.error || 'Could not start payment');
        }
        window.location.href = data.url;
      } catch (err) {
        showCiError((err as Error).message || 'Something went wrong');
      }
    }

    function showCiProcessing() {
      if (ciStepSearch) ciStepSearch.style.display = 'none';
      if (ciStepPay) ciStepPay.style.display = 'flex';
      if (ciPayButtons) ciPayButtons.style.display = 'none';
      if (ciProcessing) ciProcessing.style.display = 'flex';
      if (ciError) ciError.style.display = 'none';
    }

    function showCiError(msg: string) {
      if (ciProcessing) ciProcessing.style.display = 'none';
      if (ciPayButtons) ciPayButtons.style.display = 'flex';
      if (ciError) {
        ciError.textContent = msg;
        ciError.style.display = 'block';
      }
    }

    if (hereBtn) {
      hereBtn.addEventListener('click', openCheckin);
    }
    if (ciClose) {
      ciClose.addEventListener('click', closeCheckin);
    }
    if (ciModal) {
      ciModal.addEventListener('click', (e) => {
        if (e.target === ciModal) closeCheckin();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && ciModal.getAttribute('aria-hidden') === 'false') closeCheckin();
      });
    }
    if (ciSearch) {
      ciSearch.addEventListener('input', () => {
        if (_ciDebounce) clearTimeout(_ciDebounce);
        _ciDebounce = setTimeout(doCheckinSearch, 300);
      });
    }
    if (ciResults) {
      ciResults.addEventListener('click', (e) => {
        const item = (e.target as HTMLElement).closest('.ci-result-item') as HTMLElement | null;
        if (item) selectGuest(item.dataset.id!, item.dataset.name!);
      });
    }
    // --- Walk-in flow ---
    if (ciWalkinBtn) {
      ciWalkinBtn.addEventListener('click', () => {
        if (ciStepSearch) ciStepSearch.style.display = 'none';
        if (ciStepWalkin) ciStepWalkin.style.display = 'flex';
        setTimeout(() => ciWalkinName?.focus(), 100);
      });
    }

    if (ciWalkinName) {
      ciWalkinName.addEventListener('input', () => {
        if (ciWalkinSubmit) ciWalkinSubmit.disabled = !ciWalkinName.value.trim();
      });
    }

    // Enter key navigation between walk-in fields
    ciWalkinName?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && ciWalkinName.value.trim()) ciWalkinPhone?.focus();
    });
    ciWalkinPhone?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') ciWalkinEmail?.focus();
    });
    ciWalkinEmail?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && ciWalkinName?.value.trim()) submitWalkin();
    });

    if (ciWalkinSubmit) {
      ciWalkinSubmit.addEventListener('click', submitWalkin);
    }

    async function submitWalkin() {
      const wName = ciWalkinName?.value.trim();
      if (!wName) return;

      _ciIsWalkin = true;
      const price = getEffectivePrice();

      if (price === 0) {
        // Free: create walk-in and go straight to confirmed
        showCiProcessing();
        try {
          const res = await fetch(`/api/checkin/${ciSlug}/walkin`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: _ciBody({
              name: wName,
              phone: ciWalkinPhone?.value.trim() || undefined,
              email: ciWalkinEmail?.value.trim() || undefined,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Walk-in failed');
          window.location.href = `/checkin/${ciSlug}/confirmed?rsvp_id=${data.rsvpId}&method=free`;
        } catch (err) {
          showCiError((err as Error).message || 'Something went wrong');
        }
        return;
      }

      // Paid: show payment step
      if (ciSelectedName) ciSelectedName.textContent = wName;
      if (ciPrice) ciPrice.textContent = `$${price.toFixed(0)}`;
      if (ciStepWalkin) ciStepWalkin.style.display = 'none';
      if (ciStepPay) ciStepPay.style.display = 'flex';
      if (ciPayButtons) ciPayButtons.style.display = 'flex';
      if (ciProcessing) ciProcessing.style.display = 'none';
      if (ciError) ciError.style.display = 'none';
    }

    async function doWalkinCash() {
      const wName = ciWalkinName?.value.trim();
      if (!wName) return;
      showCiProcessing();
      try {
        const res = await fetch(`/api/checkin/${ciSlug}/walkin?method=cash`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: _ciBody({
            name: wName,
            phone: ciWalkinPhone?.value.trim() || undefined,
            email: ciWalkinEmail?.value.trim() || undefined,
          }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Walk-in failed');
        window.location.href = `/checkin/${ciSlug}/confirmed?rsvp_id=${data.rsvpId}&method=cash`;
      } catch (err) {
        showCiError((err as Error).message || 'Something went wrong');
      }
    }

    async function doWalkinCard() {
      const wName = ciWalkinName?.value.trim();
      if (!wName) return;
      showCiProcessing();
      try {
        // First create the RSVP without marking arrived (card pending)
        const walkinRes = await fetch(`/api/checkin/${ciSlug}/walkin?method=pending`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: _ciBody({
            name: wName,
            phone: ciWalkinPhone?.value.trim() || undefined,
            email: ciWalkinEmail?.value.trim() || undefined,
          }),
        });
        const walkinData = await walkinRes.json();
        if (!walkinRes.ok) throw new Error(walkinData.error || 'Walk-in failed');

        // Then create checkout session with the new RSVP ID
        const checkoutRes = await fetch(`/api/checkin/${ciSlug}/create-checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: _ciBody({ rsvpId: walkinData.rsvpId }),
        });
        const checkoutData = await checkoutRes.json();
        if (!checkoutRes.ok) throw new Error(checkoutData.error || 'Could not start payment');
        window.location.href = checkoutData.url;
      } catch (err) {
        showCiError((err as Error).message || 'Something went wrong');
      }
    }

    // Cash/card buttons route to walk-in or RSVP handler
    document.getElementById('ci-btn-cash')?.addEventListener('click', () => {
      if (_ciIsWalkin) doWalkinCash();
      else doCashCheckin();
    });
    document.getElementById('ci-btn-card')?.addEventListener('click', () => {
      if (_ciIsWalkin) doWalkinCard();
      else doCardCheckin();
    });

    // --- Menu overlay (footer tap) ---
    const footerBar = document.getElementById('footer-bar');
    const menuClose = document.getElementById('menu-close');

    if (footerBar && menuOverlay && menuContent && menuClose) {
      function openMenu() {
        menuOverlay.setAttribute('aria-hidden', 'false');
        menuOverlay.style.display = 'flex';
        gsap.fromTo(menuOverlay, { opacity: 0 }, { duration: 0.3, opacity: 1, ease: 'power2.out' });
        gsap.fromTo(
          menuContent,
          { y: '100%' },
          { duration: 0.4, y: '0%', ease: 'power3.out', delay: 0.05 },
        );
      }

      function closeMenu() {
        gsap.to(menuContent, {
          duration: 0.3,
          y: '100%',
          ease: 'power2.in',
        });
        gsap.to(menuOverlay, {
          duration: 0.25,
          opacity: 0,
          delay: 0.1,
          ease: 'power2.in',
          onComplete: () => {
            menuOverlay.style.display = 'none';
            menuOverlay.setAttribute('aria-hidden', 'true');
          },
        });
      }

      footerBar.addEventListener('click', openMenu);
      menuClose.addEventListener('click', closeMenu);
      menuOverlay.addEventListener('click', (e) => {
        if (e.target === menuOverlay) closeMenu();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && menuOverlay.getAttribute('aria-hidden') === 'false') closeMenu();
      });
    }

    // --- Entrance animations ---
    gsap.fromTo(
      '.flyer-card',
      { opacity: 0, scale: 0.9 },
      { duration: 1, opacity: 1, scale: 1, ease: 'power3.out' },
    );
    gsap.fromTo(
      '.wordmark',
      { opacity: 0, scale: 0.95 },
      { duration: 1, opacity: 1, scale: 1, ease: 'power3.out' },
    );
    gsap.fromTo(
      '.actions',
      { opacity: 0 },
      { duration: 0.6, opacity: 1, delay: 0.5, ease: 'power2.out' },
    );
    gsap.fromTo(
      '.landing-footer',
      { opacity: 0 },
      { duration: 0.6, opacity: 1, delay: 0.7, ease: 'power2.out' },
    );
  });
</script>

