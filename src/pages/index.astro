---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';

// Get upcoming published events
const { data: events } = await supabase
  .from('events')
  .select('title, slug, date, venue_name, door_price, flyer_url')
  .eq('status', 'published')
  .gte('date', new Date().toISOString())
  .order('date', { ascending: true });

const upcoming = events ?? [];

// If exactly one upcoming event, could redirect — but showing the page is friendlier
const nextEvent = upcoming[0] ?? null;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return {
    weekday: d.toLocaleDateString('en-US', { weekday: 'long' }),
    date: d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' }),
    time: d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }),
  };
}
---
<Base title="Stop One">
  <main class="home">
    <header class="hero">
      <h1 class="logo">Stop One</h1>
      <p class="tagline">Recurring DIY party series</p>
    </header>

    {upcoming.length === 0 ? (
      <div class="empty-state">
        <p>No upcoming events right now.</p>
        <p class="text-muted">Check back soon.</p>
      </div>
    ) : (
      <section class="events">
        <h2 class="section-title">Upcoming</h2>
        <div class="event-cards">
          {upcoming.map((event) => {
            const { weekday, date, time } = formatDate(event.date);
            return (
              <a href={`/events/${event.slug}`} class="event-card">
                {event.flyer_url && (
                  <img src={event.flyer_url} alt="" class="event-card-flyer" loading="lazy" />
                )}
                <div class="event-card-body">
                  <h3 class="event-card-title">{event.title}</h3>
                  <div class="event-card-details">
                    <span class="event-card-date">{weekday}, {date}</span>
                    <span class="event-card-time">{time}</span>
                    {event.venue_name && <span class="event-card-venue">{event.venue_name}</span>}
                  </div>
                  {Number(event.door_price) > 0 && (
                    <span class="event-card-price">${Number(event.door_price)}</span>
                  )}
                </div>
                <span class="event-card-cta">RSVP &rarr;</span>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </main>
</Base>

<style>
  .home {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .hero {
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }

  .logo {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-accent);
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    margin-top: var(--space-2);
  }

  .empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-10) 0;
    text-align: center;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .event-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .event-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .event-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    transform: translateY(-2px);
  }

  .event-card-flyer {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .event-card-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .event-card-title {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .event-card-details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-4);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .event-card-price {
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--color-text);
    font-size: 0.875rem;
  }

  .event-card-cta {
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--color-border);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-accent);
    transition: background var(--transition);
  }

  .event-card:hover .event-card-cta {
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
</style>
