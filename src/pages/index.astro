---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';

// Get next upcoming published event
const { data: events } = await supabase
  .from('events')
  .select('title, slug, date')
  .eq('status', 'published')
  .gte('date', new Date().toISOString())
  .order('date', { ascending: true })
  .limit(1);

const nextEvent = events?.[0] ?? null;
const eventDate = nextEvent ? new Date(nextEvent.date) : null;
---
<Base title="Stop One">
  <main class="landing">
    <div class="landing-content">
      <div class="hero-block">
        <img src="/images/wordmark.svg" alt="Stop One" class="wordmark" />
        {eventDate ? (
          <p class="countdown" data-target={eventDate.toISOString()}>
            <span class="countdown-label">in</span>
            <span id="countdown-days">0</span><span class="countdown-unit">d</span>
            <span id="countdown-hours">0</span><span class="countdown-unit">h</span>
            <span id="countdown-mins">0</span><span class="countdown-unit">m</span>
          </p>
        ) : (
          <p class="countdown countdown-tba">Next event TBA</p>
        )}
      </div>

      {nextEvent ? (
        <a href={`/events/${nextEvent.slug}`} class="rsvp-link" id="rsvp-btn">
          <span class="rsvp-text">RSVP</span>
        </a>
      ) : null}
    </div>

    <footer class="landing-footer">
      <a href="/admin/login" class="admin-link">Admin</a>
    </footer>
  </main>
</Base>

<script>
  import gsap from 'gsap';

  document.addEventListener('astro:page-load', () => {
    gsap.killTweensOf('.wordmark, .countdown, .rsvp-link, .landing-footer');

    // Countdown timer
    const countdownEl = document.querySelector('.countdown');
    if (countdownEl && countdownEl.hasAttribute('data-target')) {
      const target = new Date(countdownEl.getAttribute('data-target')!);
      const daysEl = document.getElementById('countdown-days');
      const hoursEl = document.getElementById('countdown-hours');
      const minsEl = document.getElementById('countdown-mins');

      function updateCountdown() {
        const now = new Date();
        const diff = target.getTime() - now.getTime();
        if (diff <= 0) {
          if (daysEl) daysEl.textContent = '0';
          if (hoursEl) hoursEl.textContent = '0';
          if (minsEl) minsEl.textContent = '0';
          return;
        }
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        if (daysEl) daysEl.textContent = String(days);
        if (hoursEl) hoursEl.textContent = String(hours);
        if (minsEl) minsEl.textContent = String(mins);
      }
      updateCountdown();
      setInterval(updateCountdown, 60000);
    }

    // RSVP hover animation
    const rsvpBtn = document.getElementById('rsvp-btn');
    if (rsvpBtn) {
      const textEl = rsvpBtn.querySelector('.rsvp-text');
      if (textEl) {
        rsvpBtn.addEventListener('mouseenter', () => {
          gsap.to(textEl, {
            duration: 0.3,
            ease: 'power2.out',
            onStart: () => { textEl.textContent = 'RESERVE YOUR PLAY'; }
          });
          gsap.fromTo(textEl,
            { letterSpacing: '0.1em' },
            { duration: 0.4, ease: 'power2.out', letterSpacing: '0.25em' }
          );
        });
        rsvpBtn.addEventListener('mouseleave', () => {
          gsap.to(textEl, {
            duration: 0.2,
            ease: 'power2.in',
            letterSpacing: '0.1em',
            onComplete: () => { textEl.textContent = 'RSVP'; }
          });
        });
      }
    }

    // Entrance animations — explicit start/end to avoid ViewTransition opacity conflicts
    gsap.fromTo('.wordmark', { opacity: 0, scale: 0.95 }, { duration: 1, opacity: 1, scale: 1, ease: 'power3.out' });
    gsap.fromTo('.countdown', { opacity: 0 }, { duration: 0.6, opacity: 1, delay: 0.4, ease: 'power2.out' });
    gsap.fromTo('.rsvp-link', { opacity: 0, y: 20 }, { duration: 0.8, opacity: 1, y: 0, delay: 0.6, ease: 'power3.out' });
    gsap.fromTo('.landing-footer', { opacity: 0 }, { duration: 0.6, opacity: 0.3, delay: 0.8, ease: 'power2.out' });
  });
</script>

<style>
  .landing {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl) var(--space-lg);
  }

  .landing-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3xl);
    text-align: center;
    flex: 1;
    justify-content: center;
  }

  .hero-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .wordmark {
    height: 10rem;
    width: auto;
  }

  @media (min-width: 768px) {
    .wordmark { height: 13rem; }
  }

  .countdown {
    font-size: 0.8125rem;
    font-weight: var(--weight-regular);
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .countdown-label {
    margin-right: 0.25em;
  }

  .countdown-unit {
    margin-right: 0.4em;
    opacity: 0.5;
  }

  .countdown-tba {
    opacity: 0.5;
  }

  .rsvp-link {
    font-size: 1rem;
    font-weight: var(--weight-bold);
    text-decoration: none;
    letter-spacing: 0.1em;
    padding: var(--space-sm) var(--space-xl);
    border: 2px solid var(--color-fg);
    background: var(--color-fg);
    color: var(--color-bg);
    transition: all 0.2s ease;
  }

  .rsvp-link:hover {
    background: transparent;
    color: var(--color-fg);
    opacity: 1;
  }

  .rsvp-text {
    display: inline-block;
  }

  .landing-footer {
    padding-top: var(--space-xl);
    opacity: 0.3;
    transition: opacity var(--transition);
  }

  .landing-footer:hover {
    opacity: 0.7;
  }

  .admin-link {
    font-size: 0.75rem;
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
</style>
