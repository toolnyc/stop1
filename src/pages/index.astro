---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';

// Get upcoming published events
const { data: events } = await supabase
  .from('events')
  .select('title, slug, date, venue_name, door_price, flyer_url')
  .eq('status', 'published')
  .gte('date', new Date().toISOString())
  .order('date', { ascending: true });

const upcoming = events ?? [];

// If exactly one upcoming event, could redirect — but showing the page is friendlier
const nextEvent = upcoming[0] ?? null;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return {
    weekday: d.toLocaleDateString('en-US', { weekday: 'long' }),
    date: d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' }),
    time: d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }),
  };
}
---
<Base title="Stop One">
  <main class="home">
    <header class="hero">
      <h1 class="logo">
        <img src="/images/wordmark.svg" alt="stop1" class="wordmark" />
      </h1>
      <p class="tagline">Recurring DIY party series</p>
    </header>

    {upcoming.length === 0 ? (
      <div class="empty-state">
        <p>No upcoming events right now.</p>
        <p class="text-muted">Check back soon.</p>
      </div>
    ) : (
      <section class="events">
        <h2 class="section-title">[Upcoming]</h2>
        <div class="event-cards">
          {upcoming.map((event) => {
            const { weekday, date, time } = formatDate(event.date);
            return (
              <a href={`/events/${event.slug}`} class="event-card">
                {event.flyer_url && (
                  <img src={event.flyer_url} alt="" class="event-card-flyer" loading="lazy" />
                )}
                <div class="event-card-body">
                  <h3 class="event-card-title">{event.title}</h3>
                  <div class="event-card-details">
                    <span class="event-card-date">{weekday}, {date}</span>
                    <span class="event-card-time">{time}</span>
                    {event.venue_name && <span class="event-card-venue">{event.venue_name}</span>}
                  </div>
                  {Number(event.door_price) > 0 && (
                    <span class="event-card-price">${Number(event.door_price)}</span>
                  )}
                </div>
                <span class="event-card-cta">RSVP &rarr;</span>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </main>
</Base>

<style>
  .home {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    text-align: center;
  }

  .logo {
    line-height: 1;
  }

  .wordmark {
    height: 2.5rem;
    width: auto;
  }

  .tagline {
    color: var(--color-muted);
    font-size: 1.0625rem;
    font-weight: var(--weight-light);
    margin-top: var(--space-sm);
  }

  .empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-3xl) 0;
    text-align: center;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-muted);
    margin-bottom: var(--space-md);
  }

  .event-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .event-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: var(--border);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-fg);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .event-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .event-card-flyer {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .event-card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .event-card-title {
    font-size: 1.375rem;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
  }

  .event-card-details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .event-card-price {
    font-weight: var(--weight-medium);
    font-family: var(--font-mono);
    color: var(--color-fg);
    font-size: 0.875rem;
  }

  .event-card-cta {
    padding: var(--space-sm) var(--space-lg);
    border-top: var(--border);
    font-weight: var(--weight-medium);
    font-size: 0.875rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    transition: background var(--transition);
  }

  .event-card:hover .event-card-cta {
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
</style>
