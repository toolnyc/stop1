---
import Base from '@/layouts/Base.astro';
import { supabase } from '@/lib/supabase';
import { EVENT_TIMEZONE } from '@/lib/constants';

// Get next upcoming published event
const { data: events } = await supabase
  .from('events')
  .select(
    'title, slug, date, time_end, flyer_url, venue_name, venue_address, description, door_price, early_price, early_cutoff',
  )
  .eq('status', 'published')
  .gte('date', new Date().toISOString())
  .order('date', { ascending: true })
  .limit(1);

const nextEvent = events?.[0] ?? null;
const eventDate = nextEvent ? new Date(nextEvent.date) : null;

const formatTime = (date: Date) => {
  return date
    .toLocaleTimeString('en-US', {
      hour: 'numeric',
      minute: '2-digit',
      hour12: true,
      timeZone: EVENT_TIMEZONE,
    })
    .toLowerCase()
    .replace(':00', '')
    .replace(' ', '');
};

// Format event details for the info modal
const dateFormatted = eventDate
  ? eventDate.toLocaleDateString('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      timeZone: EVENT_TIMEZONE,
    })
  : null;

const timeFormatted = eventDate ? formatTime(eventDate) : null;
const timeEnd = nextEvent?.time_end ? formatTime(new Date(nextEvent.time_end)) : null;

const formatPrice = (price: number) => (price === 0 ? 'free' : `$${Math.floor(price)}`);

const hasEarlyPricing =
  nextEvent?.early_price !== null &&
  nextEvent?.early_price !== undefined &&
  nextEvent?.early_cutoff;

const earlyPriceFormatted = hasEarlyPricing ? formatPrice(nextEvent.early_price!) : null;
const earlyTimeFormatted = hasEarlyPricing ? formatTime(new Date(nextEvent.early_cutoff!)) : null;
const doorPriceFormatted =
  nextEvent?.door_price !== null && nextEvent?.door_price !== undefined
    ? formatPrice(nextEvent.door_price)
    : null;
---

<Base title="Stop One">
  <main class="landing">
    <div class="landing-content">
      {
        nextEvent?.flyer_url ? (
          <div class="flyer-scene" id="flyer-scene">
            <div class="flyer-card" id="flyer-card">
              <div class="flyer-shine" id="flyer-shine" />
              <img
                src={nextEvent.flyer_url}
                alt={`${nextEvent.title} flyer`}
                class="flyer-img"
                loading="eager"
                draggable="false"
              />
            </div>
          </div>
        ) : (
          <img src="/images/wordmark.svg" alt="Stop One" class="wordmark" />
        )
      }

      {
        nextEvent ? (
          <div class="actions">
            <a href={`/events/${nextEvent.slug}`} class="action-btn">
              RSVP
            </a>
            <button type="button" class="action-btn" id="info-btn">
              Info
            </button>
            <button type="button" class="action-btn" id="gl-btn" data-slug={nextEvent.slug}>
              List
            </button>
          </div>
        ) : null
      }
    </div>

    <footer class="landing-footer dark-ctx" id="footer-bar">
      <div class="footer-slot" id="footer-slot">
        <span class="footer-item footer-text" data-idx="0">your first</span>
        <span class="footer-item footer-text" data-idx="1">your last</span>
        <span class="footer-item footer-text" data-idx="2">your only</span>
        <img
          class="footer-item footer-logo"
          data-idx="3"
          src="/images/wordmark.svg"
          alt="Stop One"
        />
      </div>
    </footer>

    {/* Info modal */}
    {
      nextEvent && (
        <div class="modal-backdrop" id="info-modal" aria-hidden="true">
          <div class="modal-sheet" role="dialog" aria-label="Event info">
            <button type="button" class="modal-close" id="modal-close" aria-label="Close">
              &times;
            </button>
            <div class="modal-body">
              <h2 class="modal-title">{nextEvent.title}</h2>

              <dl class="info-list">
                {dateFormatted && (
                  <div class="info-row">
                    <dt class="info-label">Date</dt>
                    <dd class="info-value">{dateFormatted}</dd>
                  </div>
                )}

                {timeFormatted && (
                  <div class="info-row">
                    <dt class="info-label">Time</dt>
                    <dd class="info-value">
                      {timeFormatted}
                      {timeEnd ? `\u2013${timeEnd}` : ''}
                    </dd>
                  </div>
                )}

                {(doorPriceFormatted || earlyPriceFormatted) && (
                  <div class="info-row">
                    <dt class="info-label">Price</dt>
                    <dd class="info-value">
                      {hasEarlyPricing ? (
                        <span>
                          {earlyPriceFormatted} before {earlyTimeFormatted} &middot;{' '}
                          {doorPriceFormatted} after
                        </span>
                      ) : (
                        doorPriceFormatted
                      )}
                    </dd>
                  </div>
                )}

                {nextEvent.venue_name && (
                  <div class="info-row">
                    <dt class="info-label">Location</dt>
                    <dd class="info-value">
                      {nextEvent.venue_name}
                      {nextEvent.venue_address && (
                        <span class="info-sub">{nextEvent.venue_address}</span>
                      )}
                    </dd>
                  </div>
                )}
              </dl>

              {nextEvent.description && <p class="modal-desc">{nextEvent.description}</p>}
            </div>
          </div>
        </div>
      )
    }

    {/* Guest list overlay */}
    {
      nextEvent && (
        <div class="gl-backdrop" id="gl-modal" aria-hidden="true">
          <div class="gl-sheet" id="gl-sheet" role="dialog" aria-label="Guest list">
            <div class="gl-header">
              <span class="gl-title">guest list</span>
              <span class="gl-count" id="gl-count" />
              <button type="button" class="gl-close" id="gl-close" aria-label="Close">
                &times;
              </button>
            </div>
            <div class="gl-body">
              <ul class="gl-list" id="gl-list" />
            </div>
          </div>
        </div>
      )
    }

    {/* Toast notification */}
    <div class="gl-toast" id="gl-toast" aria-live="polite" aria-atomic="true"></div>

    {/* Menu overlay with login */}
    <div class="menu-overlay" id="menu-overlay" aria-hidden="true">
      <button type="button" class="menu-close" id="menu-close" aria-label="Close">&times;</button>
      <div class="menu-content">
        <form method="POST" action="/api/admin/login" class="menu-login">
          <label>
            <span>Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
            />
          </label>
          <label>
            <span>Password</span>
            <input type="password" name="password" required autocomplete="current-password" />
          </label>
          <button type="submit" class="btn btn-primary btn-block">Sign in</button>
        </form>
      </div>
    </div>
  </main>
</Base>

<script>
  import gsap from 'gsap';

  // Module-level state so cleanup works across navigations
  let _rafId: number | null = null;
  let _handleOrientation: ((e: DeviceOrientationEvent) => void) | null = null;
  let _phraseInterval: ReturnType<typeof setInterval> | null = null;
  let _guestPollInterval: ReturnType<typeof setInterval> | null = null;
  let _glObserver: IntersectionObserver | null = null;
  let _knownGuests = new Set<string>();
  let _toastTimeout: ReturnType<typeof setTimeout> | null = null;

  function cleanup() {
    if (_rafId) {
      cancelAnimationFrame(_rafId);
      _rafId = null;
    }
    if (_handleOrientation) {
      window.removeEventListener('deviceorientation', _handleOrientation);
      _handleOrientation = null;
    }
    if (_phraseInterval) {
      clearInterval(_phraseInterval);
      _phraseInterval = null;
    }
    if (_guestPollInterval) {
      clearInterval(_guestPollInterval);
      _guestPollInterval = null;
    }
    if (_glObserver) {
      _glObserver.disconnect();
      _glObserver = null;
    }
    if (_toastTimeout) {
      clearTimeout(_toastTimeout);
      _toastTimeout = null;
    }
    _knownGuests = new Set();
  }

  document.addEventListener('astro:before-swap', cleanup);

  document.addEventListener('astro:page-load', () => {
    cleanup();
    gsap.killTweensOf(
      '.flyer-card, .wordmark, .actions, .landing-footer, .modal-backdrop, .modal-sheet, .menu-overlay, .menu-content, .footer-text, .footer-logo, .gl-backdrop, .gl-sheet',
    );

    // Reset GSAP-animated elements to clean state (targeted, not nuclear)
    const gsapTargets =
      '.flyer-card, .wordmark, .actions, .landing-footer, .modal-backdrop, .modal-sheet, .menu-overlay, .menu-content, .footer-item, .gl-backdrop, .gl-sheet';
    document.querySelectorAll<HTMLElement>(gsapTargets).forEach((el) => {
      if (el.style.length > 0) el.removeAttribute('style');
    });

    // Re-apply the initial display:none states that the server renders
    const hiddenByDefault = ['#info-modal', '#menu-overlay', '#gl-modal'];
    hiddenByDefault.forEach((sel) => {
      const el = document.querySelector<HTMLElement>(sel);
      if (el) {
        el.setAttribute('aria-hidden', 'true');
        el.style.display = 'none';
      }
    });

    // Footer items: show first, hide rest
    document.querySelectorAll<HTMLElement>('.footer-item').forEach((el, i) => {
      el.style.display = i === 0 ? 'block' : 'none';
      el.style.opacity = i === 0 ? '1' : '0';
    });

    // Grab refs we need below
    const card = document.getElementById('flyer-card');
    const shine = document.getElementById('flyer-shine');
    const modal = document.getElementById('info-modal');
    const modalSheet = modal?.querySelector('.modal-sheet') as HTMLElement | null;
    const menuOverlay = document.getElementById('menu-overlay');
    const menuContent = menuOverlay?.querySelector('.menu-content') as HTMLElement | null;

    // --- Interactive flyer card ---
    const scene = document.getElementById('flyer-scene');

    if (scene && card && shine) {
      const MAX_TILT = 6;
      let gyroActive = false;
      let currentRotateX = 0;
      let currentRotateY = 0;
      let targetRotateX = 0;
      let targetRotateY = 0;

      function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
      }

      function updateCard() {
        currentRotateX = lerp(currentRotateX, targetRotateX, 0.05);
        currentRotateY = lerp(currentRotateY, targetRotateY, 0.05);

        card.style.transform = `perspective(1200px) rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg)`;

        const shineX = 50 + (currentRotateY / MAX_TILT) * 40;
        const shineY = 50 - (currentRotateX / MAX_TILT) * 40;
        shine.style.background = `radial-gradient(circle at ${shineX}% ${shineY}%, rgba(255,255,255,0.08) 0%, transparent 80%)`;

        _rafId = requestAnimationFrame(updateCard);
      }

      _rafId = requestAnimationFrame(updateCard);

      function handleOrientation(e: DeviceOrientationEvent) {
        if (e.gamma === null || e.beta === null) return;
        gyroActive = true;
        targetRotateY = Math.max(-MAX_TILT, Math.min(MAX_TILT, e.gamma * 0.4));
        targetRotateX = Math.max(-MAX_TILT, Math.min(MAX_TILT, (e.beta - 45) * -0.3));
      }
      _handleOrientation = handleOrientation;

      if (
        typeof DeviceOrientationEvent !== 'undefined' &&
        typeof (DeviceOrientationEvent as unknown as { requestPermission?: () => Promise<string> })
          .requestPermission === 'function'
      ) {
        scene.addEventListener(
          'click',
          async () => {
            if (gyroActive) return;
            try {
              const permission = await (
                DeviceOrientationEvent as unknown as { requestPermission: () => Promise<string> }
              ).requestPermission();
              if (permission === 'granted') {
                window.addEventListener('deviceorientation', handleOrientation);
              }
            } catch {
              /* user denied */
            }
          },
          { once: true },
        );
      } else {
        window.addEventListener('deviceorientation', handleOrientation);
      }

      scene.addEventListener(
        'touchmove',
        (e) => {
          if (gyroActive) return;
          const touch = e.touches[0];
          const rect = scene.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const x = (touch.clientX - centerX) / (rect.width / 2);
          const y = (touch.clientY - centerY) / (rect.height / 2);
          targetRotateY = x * MAX_TILT;
          targetRotateX = -y * MAX_TILT;
        },
        { passive: true },
      );

      scene.addEventListener('touchend', () => {
        if (gyroActive) return;
        targetRotateX = 0;
        targetRotateY = 0;
      });

      scene.addEventListener('mousemove', (e) => {
        const rect = scene.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const x = (e.clientX - centerX) / (rect.width / 2);
        const y = (e.clientY - centerY) / (rect.height / 2);
        targetRotateY = x * MAX_TILT;
        targetRotateX = -y * MAX_TILT;
      });

      scene.addEventListener('mouseleave', () => {
        targetRotateX = 0;
        targetRotateY = 0;
      });
    }

    // --- Footer rotation: text phrases + wordmark as peers ---
    const footerItems = document.querySelectorAll<HTMLElement>('.footer-item');
    if (footerItems.length > 0) {
      let activeIdx = 0;

      function rotateFooter() {
        const current = footerItems[activeIdx];
        const nextIdx = (activeIdx + 1) % footerItems.length;
        const next = footerItems[nextIdx];

        gsap.to(current, {
          duration: 0.3,
          opacity: 0,
          y: -10,
          ease: 'power2.in',
          onComplete: () => {
            current.style.display = 'none';
            next.style.display = 'block';
            gsap.fromTo(
              next,
              { opacity: 0, y: 10 },
              { duration: 0.3, opacity: 1, y: 0, ease: 'power2.out' },
            );
            activeIdx = nextIdx;
          },
        });
      }

      _phraseInterval = setInterval(rotateFooter, 2200);
    }

    // --- Info modal ---
    const infoBtn = document.getElementById('info-btn');
    const modalClose = document.getElementById('modal-close');

    if (infoBtn && modal && modalClose && modalSheet) {
      function openModal() {
        modal.setAttribute('aria-hidden', 'false');
        modal.style.display = 'flex';
        gsap.fromTo(modal, { opacity: 0 }, { duration: 0.25, opacity: 1, ease: 'power2.out' });
        gsap.fromTo(
          modalSheet,
          { y: 40, opacity: 0 },
          { duration: 0.35, y: 0, opacity: 1, ease: 'power3.out', delay: 0.05 },
        );
      }

      function closeModal() {
        gsap.to(modal, {
          duration: 0.2,
          opacity: 0,
          ease: 'power2.in',
          onComplete: () => {
            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
          },
        });
      }

      infoBtn.addEventListener('click', openModal);
      modalClose.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
      });
    }

    // --- Guest list overlay ---
    const glBtn = document.getElementById('gl-btn');
    const glModal = document.getElementById('gl-modal');
    const glSheet = document.getElementById('gl-sheet');
    const glClose = document.getElementById('gl-close');
    const glList = document.getElementById('gl-list');
    const glCount = document.getElementById('gl-count');
    const glToast = document.getElementById('gl-toast');
    const eventSlug = (glBtn as HTMLElement | null)?.dataset.slug;

    async function fetchGuests(): Promise<{ name: string }[]> {
      if (!eventSlug) return [];
      try {
        const res = await fetch(`/api/guests/${eventSlug}`);
        if (!res.ok) return [];
        const data = (await res.json()) as { guests: { name: string }[] };
        return data.guests;
      } catch {
        return [];
      }
    }

    function showToast(name: string) {
      if (!glToast) return;
      if (_toastTimeout) clearTimeout(_toastTimeout);
      glToast.textContent = `${name} just RSVPd!`;
      glToast.style.display = 'block';
      gsap.killTweensOf(glToast);
      gsap.fromTo(
        glToast,
        { y: -60, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.4, ease: 'power3.out' },
      );
      _toastTimeout = setTimeout(() => {
        gsap.to(glToast, {
          y: -60,
          opacity: 0,
          duration: 0.3,
          ease: 'power2.in',
          onComplete: () => {
            glToast.style.display = 'none';
          },
        });
        _toastTimeout = null;
      }, 3500);
    }

    function setupScrollObserver() {
      if (_glObserver) _glObserver.disconnect();
      _glObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('gl-item--visible');
              _glObserver?.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );
      document.querySelectorAll('.gl-item:not(.gl-item--visible)').forEach((el) => {
        _glObserver?.observe(el);
      });
    }

    async function pollGuests() {
      const guests = await fetchGuests();
      const newGuests = guests.filter((g) => !_knownGuests.has(g.name));
      if (newGuests.length === 0) return;

      newGuests.forEach((g) => _knownGuests.add(g.name));

      // Always show toast for latest arrival
      showToast(newGuests[newGuests.length - 1].name);

      // If list is open, prepend new items
      if (glList && glModal?.getAttribute('aria-hidden') === 'false') {
        glCount && (glCount.textContent = `${guests.length}`);
        [...newGuests].reverse().forEach((g) => {
          const li = document.createElement('li');
          li.className = 'gl-item gl-item--visible gl-item--new';
          li.innerHTML = `<span class="gl-name">${g.name}</span><span class="gl-suffix"> is coming</span>`;
          glList.prepend(li);
          gsap.fromTo(
            li,
            { opacity: 0, y: -16 },
            { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' },
          );
        });
      }
    }

    async function openGuestList() {
      if (!glModal || !glSheet) return;
      glModal.setAttribute('aria-hidden', 'false');
      glModal.style.display = 'flex';
      gsap.fromTo(glModal, { opacity: 0 }, { duration: 0.25, opacity: 1, ease: 'power2.out' });
      gsap.fromTo(
        glSheet,
        { y: '100%' },
        { duration: 0.4, y: '0%', ease: 'power3.out', delay: 0.05 },
      );

      // Initial load
      if (glList) {
        glList.innerHTML = '<li class="gl-loading">loading\u2026</li>';
      }
      const guests = await fetchGuests();
      _knownGuests = new Set(guests.map((g) => g.name));

      if (glList) {
        glList.innerHTML = '';
        if (guests.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'gl-empty';
          empty.textContent = 'No RSVPs yet\u2014be first!';
          glList.appendChild(empty);
        } else {
          guests.forEach((g) => {
            const li = document.createElement('li');
            li.className = 'gl-item';
            li.innerHTML = `<span class="gl-name">${g.name}</span><span class="gl-suffix"> is coming</span>`;
            glList.appendChild(li);
          });
          // Stagger in visible items, let IntersectionObserver handle the rest
          gsap.fromTo(
            '.gl-item',
            { opacity: 0, y: 14 },
            {
              opacity: 1,
              y: 0,
              duration: 0.4,
              stagger: 0.05,
              ease: 'power2.out',
              onComplete: () => {
                document
                  .querySelectorAll('.gl-item')
                  .forEach((el) => el.classList.add('gl-item--visible'));
                setupScrollObserver();
              },
            },
          );
        }
      }

      if (glCount) glCount.textContent = `${guests.length}`;

      // Start polling for new RSVPs
      if (_guestPollInterval) clearInterval(_guestPollInterval);
      _guestPollInterval = setInterval(pollGuests, 15000);
    }

    function closeGuestList() {
      if (_guestPollInterval) {
        clearInterval(_guestPollInterval);
        _guestPollInterval = null;
      }
      if (_glObserver) {
        _glObserver.disconnect();
        _glObserver = null;
      }
      if (!glModal || !glSheet) return;
      gsap.to(glSheet, { y: '100%', duration: 0.35, ease: 'power2.in' });
      gsap.to(glModal, {
        opacity: 0,
        duration: 0.25,
        delay: 0.1,
        ease: 'power2.in',
        onComplete: () => {
          glModal.style.display = 'none';
          glModal.setAttribute('aria-hidden', 'true');
        },
      });
    }

    if (glBtn && glModal && glClose) {
      glBtn.addEventListener('click', openGuestList);
      glClose.addEventListener('click', closeGuestList);
      glModal.addEventListener('click', (e) => {
        if (e.target === glModal) closeGuestList();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && glModal.getAttribute('aria-hidden') === 'false') closeGuestList();
      });
    }

    // Background poll (toast only) — active whenever the page is loaded with an event
    if (eventSlug) {
      // Seed known guests silently so first poll only toasts truly new arrivals
      fetchGuests().then((guests) => {
        guests.forEach((g) => _knownGuests.add(g.name));
        // Start background poll at 30s so toasts fire even with list closed
        _guestPollInterval = setInterval(pollGuests, 30000);
      });
    }

    // --- Menu overlay (footer tap) ---
    const footerBar = document.getElementById('footer-bar');
    const menuClose = document.getElementById('menu-close');

    if (footerBar && menuOverlay && menuContent && menuClose) {
      function openMenu() {
        menuOverlay.setAttribute('aria-hidden', 'false');
        menuOverlay.style.display = 'flex';
        gsap.fromTo(menuOverlay, { opacity: 0 }, { duration: 0.3, opacity: 1, ease: 'power2.out' });
        gsap.fromTo(
          menuContent,
          { y: '100%' },
          { duration: 0.4, y: '0%', ease: 'power3.out', delay: 0.05 },
        );
      }

      function closeMenu() {
        gsap.to(menuContent, {
          duration: 0.3,
          y: '100%',
          ease: 'power2.in',
        });
        gsap.to(menuOverlay, {
          duration: 0.25,
          opacity: 0,
          delay: 0.1,
          ease: 'power2.in',
          onComplete: () => {
            menuOverlay.style.display = 'none';
            menuOverlay.setAttribute('aria-hidden', 'true');
          },
        });
      }

      footerBar.addEventListener('click', openMenu);
      menuClose.addEventListener('click', closeMenu);
      menuOverlay.addEventListener('click', (e) => {
        if (e.target === menuOverlay) closeMenu();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && menuOverlay.getAttribute('aria-hidden') === 'false') closeMenu();
      });
    }

    // --- Entrance animations ---
    gsap.fromTo(
      '.flyer-card',
      { opacity: 0, scale: 0.9 },
      { duration: 1, opacity: 1, scale: 1, ease: 'power3.out' },
    );
    gsap.fromTo(
      '.wordmark',
      { opacity: 0, scale: 0.95 },
      { duration: 1, opacity: 1, scale: 1, ease: 'power3.out' },
    );
    gsap.fromTo(
      '.actions',
      { opacity: 0 },
      { duration: 0.6, opacity: 1, delay: 0.5, ease: 'power2.out' },
    );
    gsap.fromTo(
      '.landing-footer',
      { opacity: 0 },
      { duration: 0.6, opacity: 1, delay: 0.7, ease: 'power2.out' },
    );
  });
</script>

<style>
  .landing {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl) var(--space-lg) 0;
    overflow-x: hidden;
  }

  .landing-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
