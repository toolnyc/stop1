---
import Base from '@/layouts/Base.astro';
import RsvpForm from '@/components/public/RsvpForm.astro';
import { supabase } from '@/lib/supabase';

const { slug } = Astro.params;

const { data: event, error } = await supabase
  .from('events')
  .select('*')
  .eq('slug', slug!)
  .eq('status', 'published')
  .single();

if (error || !event) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const eventDate = new Date(event.date);
const dateFormatted = eventDate.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const timeFormatted = eventDate.toLocaleTimeString('en-US', {
  hour: 'numeric',
  minute: '2-digit',
});
const timeEnd = event.time_end
  ? new Date(event.time_end).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })
  : null;
---
<Base title={`${event.title} — Stop One`} description={`RSVP for ${event.title}`}>
  <main class="event-page">
    <a href="/" class="back-link">
      <img src="/images/wordmark.svg" alt="Stop One" class="back-logo" />
    </a>

    {event.flyer_url && (
      <div class="flyer-container">
        <img src={event.flyer_url} alt={`${event.title} flyer`} class="event-flyer" />
      </div>
    )}

    <div class="event-info">
      <h1 class="event-title">{event.title}</h1>

      <div class="event-meta">
        <span class="meta-date">{dateFormatted}</span>
        <span class="meta-sep">•</span>
        <span class="meta-time">{timeFormatted}{timeEnd ? ` – ${timeEnd}` : ''}</span>
        {event.venue_name && (
          <>
            <span class="meta-sep">•</span>
            <span class="meta-venue">{event.venue_name}</span>
          </>
        )}
      </div>

      {Number(event.door_price) > 0 && (
        <div class="event-price mono">${Number(event.door_price)} at the door</div>
      )}

      {event.description && (
        <p class="event-description">{event.description}</p>
      )}
    </div>

    <RsvpForm slug={slug!} eventTitle={event.title} />
  </main>
</Base>

<script>
  import gsap from 'gsap';

  // Entrance animations
  gsap.from('.flyer-container', {
    duration: 0.8,
    scale: 0.95,
    opacity: 0,
    ease: 'power3.out'
  });

  gsap.from('.event-info', {
    duration: 0.8,
    y: 30,
    opacity: 0,
    delay: 0.2,
    ease: 'power3.out'
  });

  gsap.from('.rsvp-form', {
    duration: 0.8,
    y: 30,
    opacity: 0,
    delay: 0.4,
    ease: 'power3.out'
  });
</script>

<style>
  .event-page {
    max-width: 560px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md) var(--space-4xl);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: var(--space-lg);
    opacity: 0.5;
    transition: opacity var(--transition);
  }

  .back-link:hover {
    opacity: 1;
  }

  .back-logo {
    height: 1.5rem;
    width: auto;
  }

  .flyer-container {
    margin-bottom: var(--space-xl);
  }

  .event-flyer {
    width: 100%;
    height: auto;
  }

  .event-info {
    margin-bottom: var(--space-xl);
  }

  .event-title {
    font-size: 1.75rem;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-sm);
  }

  .event-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }

  .meta-sep {
    opacity: 0.4;
  }

  .event-price {
    font-size: 0.875rem;
    margin-bottom: var(--space-md);
  }

  .event-description {
    color: var(--color-muted);
    line-height: var(--leading-relaxed);
    font-size: 0.9375rem;
  }
</style>
