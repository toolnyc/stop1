---
import Admin from '@/layouts/Admin.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { slug } = Astro.params;
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');

const { data: event, error: fetchError } = await supabaseAdmin
  .from('events')
  .select('*')
  .eq('slug', slug!)
  .single();

if (fetchError || !event) {
  return Astro.redirect('/admin');
}

function formatDatetimeLocal(dateStr: string | null) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toISOString().slice(0, 16);
}
---
<Admin title={`${event.title} — Edit`}>
  <div class="edit-layout">
    <nav class="sidebar">
      <a href={`/admin/events/${slug}`} class="sidebar-link active">Edit</a>
      <a href={`/admin/events/${slug}/rsvps`} class="sidebar-link">RSVPs</a>
      <a href={`/door/${slug}`} class="sidebar-link external" target="_blank">Door</a>
      <a href={`/admin/events/${slug}/budget`} class="sidebar-link">Budget</a>
      <a href={`/admin/events/${slug}/collaborators`} class="sidebar-link">Collaborators</a>
    </nav>

    <div class="edit-content">
      <h1>Edit: {event.title}</h1>

      {error && <div class="alert alert-error">{error}</div>}
      {success && <div class="alert alert-success">{success}</div>}

      <form method="POST" action={`/api/admin/events/${slug}/update`} class="event-form">
        <label>
          <span>Title *</span>
          <input type="text" name="title" required value={event.title} />
        </label>

        <label>
          <span>Slug</span>
          <input type="text" value={event.slug} disabled />
          <small>Cannot be changed after creation.</small>
        </label>

        <div class="form-row">
          <label>
            <span>Start Date/Time *</span>
            <input type="datetime-local" name="date" required value={formatDatetimeLocal(event.date)} />
          </label>
          <label>
            <span>End Date/Time</span>
            <input type="datetime-local" name="time_end" value={formatDatetimeLocal(event.time_end)} />
          </label>
        </div>

        <label>
          <span>Venue Name</span>
          <input type="text" name="venue_name" value={event.venue_name ?? ''} />
        </label>

        <label>
          <span>Venue Address</span>
          <input type="text" name="venue_address" value={event.venue_address ?? ''} />
        </label>

        <label>
          <span>Description</span>
          <textarea name="description" rows="4">{event.description ?? ''}</textarea>
        </label>

        <div class="form-row">
          <label>
            <span>Door Price *</span>
            <input type="number" name="door_price" min="0" step="0.01" required value={event.door_price} />
          </label>
          <label>
            <span>Capacity</span>
            <input type="number" name="capacity" min="0" value={event.capacity ?? ''} />
          </label>
        </div>

        <label>
          <span>Door PIN</span>
          <input type="text" name="door_pin" inputmode="numeric" pattern="[0-9]*" placeholder="Leave blank to keep current" />
          <small>Leave blank to keep existing PIN.</small>
        </label>

        <label>
          <span>Status</span>
          <select name="status">
            <option value="draft" selected={event.status === 'draft'}>Draft</option>
            <option value="published" selected={event.status === 'published'}>Published</option>
          </select>
        </label>

        <button type="submit" class="btn btn-primary">Save Changes</button>
      </form>

      {event.status !== 'archived' && (
        <div class="danger-zone">
          <form method="POST" action={`/api/admin/events/${slug}/archive`}>
            <button type="submit" class="btn btn-danger btn-sm">Archive Event</button>
          </form>
        </div>
      )}
    </div>
  </div>
</Admin>

<style>
  .edit-layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-8);
  }

  @media (max-width: 640px) {
    .edit-layout {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .sidebar {
      flex-direction: row !important;
      overflow-x: auto;
      gap: var(--space-1) !important;
      padding-bottom: var(--space-2);
      border-bottom: 1px solid var(--color-border);
    }

    .sidebar-link {
      white-space: nowrap;
    }
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .sidebar-link {
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background var(--transition), color var(--transition);
  }

  .sidebar-link:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .sidebar-link.active {
    background: var(--color-surface);
    color: var(--color-accent);
  }

  .sidebar-link.external::after {
    content: ' ↗';
    opacity: 0.5;
  }

  .edit-content h1 {
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .event-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 600px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .alert {
    margin-bottom: var(--space-4);
    max-width: 600px;
  }

  .danger-zone {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    max-width: 600px;
  }
</style>
