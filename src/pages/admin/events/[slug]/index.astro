---
import Admin from '@/layouts/Admin.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { slug } = Astro.params;
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');

const { data: event, error: fetchError } = await supabaseAdmin
  .from('events')
  .select('*')
  .eq('slug', slug!)
  .single();

if (fetchError || !event) {
  return Astro.redirect('/admin');
}

function formatDatetimeLocal(dateStr: string | null) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toISOString().slice(0, 16);
}
---

<Admin title={`${event.title} — Edit`}>
  <div class="edit-layout">
    <nav class="sidebar">
      <a href={`/admin/events/${slug}`} class="sidebar-link active">Edit</a>
      <a href={`/admin/events/${slug}/rsvps`} class="sidebar-link">RSVPs</a>
      <a href={`/door/${slug}`} class="sidebar-link external" target="_blank">Door</a>
      <a href={`/admin/events/${slug}/budget`} class="sidebar-link">Budget</a>
      <a href={`/admin/events/${slug}/collaborators`} class="sidebar-link">Collaborators</a>
    </nav>

    <div class="edit-content">
      <h1>Edit: {event.title}</h1>

      {error && <div class="alert alert-error">{error}</div>}
      {success && <div class="alert alert-success">{success}</div>}

      <form
        method="POST"
        action={`/api/admin/events/${slug}/update`}
        enctype="multipart/form-data"
        class="event-form"
        id="event-form"
      >
        <div class="flyer-section">
          <span class="field-label">Flyer</span>
          <div class="flyer-upload" id="flyer-upload">
            {
              event.flyer_url ? (
                <div class="flyer-preview" id="flyer-preview">
                  <img
                    src={event.flyer_url}
                    alt="Current flyer"
                    class="flyer-thumb"
                    id="flyer-thumb"
                  />
                  <div class="flyer-actions">
                    <label class="btn btn-secondary btn-sm flyer-change-btn">
                      Replace
                      <input
                        type="file"
                        name="flyer"
                        accept="image/*"
                        class="sr-only"
                        id="flyer-input"
                      />
                    </label>
                    <button type="button" class="btn btn-danger btn-sm" id="flyer-remove">
                      Remove
                    </button>
                  </div>
                </div>
              ) : (
                <div class="flyer-preview" id="flyer-preview">
                  <label class="flyer-drop" id="flyer-drop">
                    <span class="flyer-drop-text">Drop flyer image here or click to upload</span>
                    <small>JPEG or PNG, max 5MB. Auto-compressed to ~1200px wide.</small>
                    <input
                      type="file"
                      name="flyer"
                      accept="image/*"
                      class="sr-only"
                      id="flyer-input"
                    />
                  </label>
                </div>
              )
            }
          </div>
          <input type="hidden" name="remove_flyer" value="false" id="remove-flyer-flag" />
          <div id="flyer-status" class="flyer-status"></div>
        </div>

        <label>
          <span>Title *</span>
          <input type="text" name="title" required value={event.title} />
        </label>

        <label>
          <span>Slug</span>
          <input type="text" value={event.slug} disabled />
          <small>Cannot be changed after creation.</small>
        </label>

        <div class="form-row">
          <label>
            <span>Start Date/Time *</span>
            <input
              type="datetime-local"
              name="date"
              required
              value={formatDatetimeLocal(event.date)}
            />
          </label>
          <label>
            <span>End Date/Time</span>
            <input
              type="datetime-local"
              name="time_end"
              value={formatDatetimeLocal(event.time_end)}
            />
          </label>
        </div>

        <label>
          <span>Venue Name</span>
          <input type="text" name="venue_name" value={event.venue_name ?? ''} />
        </label>

        <label>
          <span>Venue Address</span>
          <input type="text" name="venue_address" value={event.venue_address ?? ''} />
        </label>

        <label>
          <span>Description</span>
          <textarea name="description" rows="4">{event.description ?? ''}</textarea>
        </label>

        <div class="form-row">
          <label>
            <span>Door Price *</span>
            <input
              type="number"
              name="door_price"
              min="0"
              step="0.01"
              required
              value={event.door_price}
            />
          </label>
          <label>
            <span>Capacity</span>
            <input type="number" name="capacity" min="0" value={event.capacity ?? ''} />
          </label>
        </div>

        <label>
          <span>Door PIN</span>
          <input
            type="text"
            name="door_pin"
            inputmode="numeric"
            pattern="[0-9]*"
            placeholder="Leave blank to keep current"
          />
          <small>Leave blank to keep existing PIN.</small>
        </label>

        <label>
          <span>Status</span>
          <select name="status">
            <option value="draft" selected={event.status === 'draft'}>Draft</option>
            <option value="published" selected={event.status === 'published'}>Published</option>
          </select>
        </label>

        <button type="submit" class="btn btn-primary" id="submit-btn">Save Changes</button>
      </form>

      {
        event.status !== 'archived' && (
          <div class="danger-zone">
            <form method="POST" action={`/api/admin/events/${slug}/archive`}>
              <button type="submit" class="btn btn-danger btn-sm">
                Archive Event
              </button>
            </form>
          </div>
        )
      }
    </div>
  </div>
</Admin>

<script>
  const MAX_WIDTH = 1200;
  const JPEG_QUALITY = 0.8;

  const flyerInput = document.getElementById('flyer-input') as HTMLInputElement;
  const flyerPreview = document.getElementById('flyer-preview')!;
  const flyerStatus = document.getElementById('flyer-status')!;
  const removeFlyerFlag = document.getElementById('remove-flyer-flag') as HTMLInputElement;
  const flyerRemoveBtn = document.getElementById('flyer-remove');
  const flyerDrop = document.getElementById('flyer-drop');
  const form = document.getElementById('event-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  let compressedFile: File | null = null;

  async function compressImage(file: File): Promise<File> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => {
        let { width, height } = img;
        if (width > MAX_WIDTH) {
          height = Math.round(height * (MAX_WIDTH / width));
          width = MAX_WIDTH;
        }
        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d')!;
        ctx.drawImage(img, 0, 0, width, height);
        canvas.toBlob(
          (blob) => {
            if (!blob) return reject(new Error('Compression failed'));
            const compressed = new File([blob], file.name.replace(/\.\w+$/, '.jpg'), {
              type: 'image/jpeg',
            });
            resolve(compressed);
          },
          'image/jpeg',
          JPEG_QUALITY,
        );
      };
      img.onerror = () => reject(new Error('Failed to load image'));
      img.src = URL.createObjectURL(file);
    });
  }

  function showPreview(src: string, sizeText: string) {
    flyerPreview.innerHTML = `
      <img src="${src}" alt="Flyer preview" class="flyer-thumb" />
      <div class="flyer-actions">
        <label class="btn btn-secondary btn-sm flyer-change-btn">
          Replace
          <input type="file" name="flyer" accept="image/*" class="sr-only" id="flyer-input" />
        </label>
        <button type="button" class="btn btn-danger btn-sm" id="flyer-remove">Remove</button>
      </div>
    `;
    flyerStatus.textContent = sizeText;
    removeFlyerFlag.value = 'false';

    const newInput = document.getElementById('flyer-input') as HTMLInputElement;
    newInput.addEventListener('change', handleFileSelect);
    document.getElementById('flyer-remove')!.addEventListener('click', handleRemove);
  }

  function showDropZone() {
    flyerPreview.innerHTML = `
      <label class="flyer-drop" id="flyer-drop">
        <span class="flyer-drop-text">Drop flyer image here or click to upload</span>
        <small>JPEG or PNG, max 5MB. Auto-compressed to ~1200px wide.</small>
        <input type="file" name="flyer" accept="image/*" class="sr-only" id="flyer-input" />
      </label>
    `;
    flyerStatus.textContent = '';
    const newInput = document.getElementById('flyer-input') as HTMLInputElement;
    newInput.addEventListener('change', handleFileSelect);
    setupDragDrop();
  }

  async function handleFileSelect(e: Event) {
    const input = e.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;

    if (!file.type.startsWith('image/')) {
      flyerStatus.textContent = 'Please select an image file.';
      return;
    }

    flyerStatus.textContent = 'Compressing...';
    submitBtn.disabled = true;

    try {
      const origSize = (file.size / 1024).toFixed(0);
      compressedFile = await compressImage(file);
      const newSize = (compressedFile.size / 1024).toFixed(0);
      const previewUrl = URL.createObjectURL(compressedFile);
      showPreview(previewUrl, `${origSize}KB → ${newSize}KB`);
    } catch {
      flyerStatus.textContent = 'Failed to compress image.';
    } finally {
      submitBtn.disabled = false;
    }
  }

  function handleRemove() {
    compressedFile = null;
    removeFlyerFlag.value = 'true';
    showDropZone();
  }

  function setupDragDrop() {
    const drop = document.getElementById('flyer-drop');
    if (!drop) return;
    drop.addEventListener('dragover', (e) => {
      e.preventDefault();
      drop.classList.add('drag-over');
    });
    drop.addEventListener('dragleave', () => drop.classList.remove('drag-over'));
    drop.addEventListener('drop', (e) => {
      e.preventDefault();
      drop.classList.remove('drag-over');
      const file = (e as DragEvent).dataTransfer?.files[0];
      if (file) {
        const input = drop.querySelector('input[type="file"]') as HTMLInputElement;
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
      }
    });
  }

  // Inject compressed file into form on submit
  form.addEventListener('submit', (e) => {
    if (compressedFile) {
      e.preventDefault();
      const formData = new FormData(form);
      formData.set('flyer', compressedFile);
      fetch(form.action, { method: 'POST', body: formData }).then((res) => {
        if (res.redirected) {
          window.location.href = res.url;
        }
      });
    }
  });

  // Init existing listeners
  flyerInput?.addEventListener('change', handleFileSelect);
  flyerRemoveBtn?.addEventListener('click', handleRemove);
  setupDragDrop();
</script>

<style>
  .edit-layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-2xl);
  }

  @media (max-width: 640px) {
    .edit-layout {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .sidebar {
      flex-direction: row !important;
      overflow-x: auto;
      gap: var(--space-xs) !important;
      padding-bottom: var(--space-sm);
      border-bottom: var(--border);
    }

    .sidebar-link {
      white-space: nowrap;
    }
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .sidebar-link {
    padding: var(--space-sm) var(--space-sm);
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: var(--weight-medium);
    transition:
      background var(--transition),
      color var(--transition);
  }

  .sidebar-link:hover {
    background: var(--color-surface);
    color: var(--color-fg);
  }

  .sidebar-link.active {
    background: var(--color-surface);
    color: var(--color-accent);
  }

  .sidebar-link.external::after {
    content: ' ↗';
    opacity: 0.5;
  }

  .edit-content h1 {
    font-size: 1.5rem;
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-lg);
  }

  .event-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 600px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .alert {
    margin-bottom: var(--space-md);
    max-width: 600px;
  }

  .danger-zone {
    margin-top: var(--space-3xl);
    padding-top: var(--space-lg);
    border-top: var(--border);
    max-width: 600px;
  }

  /* Flyer upload */
  .flyer-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .field-label {
    font-size: 0.8125rem;
    font-weight: var(--weight-medium);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
  }

  .flyer-thumb {
    width: 100%;
    max-width: 300px;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: var(--border);
  }

  .flyer-actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .flyer-change-btn {
    cursor: pointer;
  }

  .flyer-status {
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>

<style is:global>
  .flyer-drop {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: var(--space-2xl) var(--space-lg);
    border: 2px dashed var(--color-border);
    cursor: pointer;
    text-align: center;
    transition:
      border-color var(--duration-fast) ease,
      background var(--duration-fast) ease;
  }

  .flyer-drop:hover,
  .flyer-drop.drag-over {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .flyer-drop-text {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-weight: var(--weight-medium);
  }

  .flyer-drop small {
    font-size: 0.75rem;
    color: var(--color-faint);
  }
</style>
