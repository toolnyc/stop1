---
import Admin from '@/layouts/Admin.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { slug } = Astro.params;

const { data: event } = await supabaseAdmin
  .from('events')
  .select('id, title')
  .eq('slug', slug!)
  .single();

if (!event) return Astro.redirect('/admin');

// Income
const { data: payments } = await supabaseAdmin
  .from('door_payments')
  .select('amount, method')
  .eq('event_id', event.id);

const paymentList = payments ?? [];
const cashTotal = paymentList.filter(p => p.method === 'cash').reduce((s, p) => s + Number(p.amount), 0);
const cardTotal = paymentList.filter(p => p.method === 'card').reduce((s, p) => s + Number(p.amount), 0);
const revenue = cashTotal + cardTotal;

// Expenses grouped by collaborator
const { data: collaborators } = await supabaseAdmin
  .from('collaborators')
  .select('id, name, payout_pct')
  .eq('event_id', event.id)
  .order('name');

const collabList = collaborators ?? [];

const { data: expenses } = await supabaseAdmin
  .from('expenses')
  .select('id, collaborator_id, description, amount, receipt_url, created_at')
  .eq('event_id', event.id)
  .order('created_at');

const expenseList = expenses ?? [];
const totalExpenses = expenseList.reduce((s, e) => s + Number(e.amount), 0);

// Payouts
const { data: payouts } = await supabaseAdmin
  .from('payouts')
  .select('id, collaborator_id, amount, method, paid_at')
  .eq('event_id', event.id)
  .order('paid_at');

const payoutList = payouts ?? [];

// P&L
const profit = revenue - totalExpenses;

// Per-collaborator calculations
type CollabSummary = {
  id: string;
  name: string;
  payout_pct: number;
  expenses: typeof expenseList;
  expenseTotal: number;
  owed: number;
  paid: number;
  balance: number;
  payouts: typeof payoutList;
};

const collabSummaries: CollabSummary[] = collabList.map(c => {
  const collabExpenses = expenseList.filter(e => e.collaborator_id === c.id);
  const collabPayouts = payoutList.filter(p => p.collaborator_id === c.id);
  const expenseTotal = collabExpenses.reduce((s, e) => s + Number(e.amount), 0);
  const owed = profit * (Number(c.payout_pct) / 100);
  const paid = collabPayouts.reduce((s, p) => s + Number(p.amount), 0);
  return {
    id: c.id,
    name: c.name,
    payout_pct: Number(c.payout_pct),
    expenses: collabExpenses,
    expenseTotal,
    owed,
    paid,
    balance: owed - paid,
    payouts: collabPayouts,
  };
});

function fmt(n: number) { return `$${n.toFixed(2)}`; }
---
<Admin title={`Budget — ${event.title}`}>
  <div class="edit-layout">
    <nav class="sidebar">
      <a href={`/admin/events/${slug}`} class="sidebar-link">Edit</a>
      <a href={`/admin/events/${slug}/rsvps`} class="sidebar-link">RSVPs</a>
      <a href={`/door/${slug}`} class="sidebar-link" target="_blank">Door ↗</a>
      <a href={`/admin/events/${slug}/budget`} class="sidebar-link active">Budget</a>
      <a href={`/admin/events/${slug}/collaborators`} class="sidebar-link">Collaborators</a>
    </nav>

    <div class="edit-content">
      <h1>Budget</h1>

      <!-- Income -->
      <section class="section">
        <h2>Income</h2>
        <div class="data-table">
          <div class="data-row"><span>Cash</span><span class="mono">{fmt(cashTotal)}</span></div>
          <div class="data-row"><span>Card</span><span class="mono">{fmt(cardTotal)}</span></div>
          <div class="data-row total"><span>Door Revenue</span><span class="mono">{fmt(revenue)}</span></div>
        </div>
      </section>

      <!-- Expenses -->
      <section class="section">
        <h2>Expenses</h2>
        {collabSummaries.map(c => (
          <div class="collab-expenses">
            <h3>{c.name} ({fmt(c.expenseTotal)})</h3>
            {c.expenses.map(e => (
              <div class="expense-line">
                <span>{e.description}</span>
                <span class="expense-right">
                  <span class="mono">{fmt(Number(e.amount))}</span>
                  {e.receipt_url && <a href={e.receipt_url} target="_blank" class="receipt">Receipt</a>}
                </span>
              </div>
            ))}
          </div>
        ))}
        <div class="data-table">
          <div class="data-row total"><span>Total Expenses</span><span class="mono">{fmt(totalExpenses)}</span></div>
        </div>
      </section>

      <!-- P&L -->
      <section class="section profit-section">
        <div class="profit-box">
          <span class="profit-label">Profit</span>
          <span class="profit-value" class:list={[{ negative: profit < 0 }]}>{fmt(profit)}</span>
        </div>
        <p class="profit-formula">Revenue ({fmt(revenue)}) − Expenses ({fmt(totalExpenses)})</p>
      </section>

      <!-- Payouts -->
      <section class="section">
        <h2>Payouts</h2>
        {collabSummaries.map(c => (
          <div class="collab-payout">
            <div class="payout-header">
              <span>{c.name} ({c.payout_pct}%)</span>
              <span class="mono">Owed: {fmt(c.owed)} | Paid: {fmt(c.paid)} | Balance: {fmt(c.balance)}</span>
            </div>
            {c.payouts.map(p => (
              <div class="payout-line">
                <span>{fmt(Number(p.amount))} via {p.method}</span>
                <span class="payout-date">{new Date(p.paid_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              </div>
            ))}
            <a href={`/admin/events/${slug}/budget?record_payout=${c.id}`} class="btn-record">Record Payout</a>
          </div>
        ))}
      </section>
    </div>
  </div>
</Admin>

<style>
  .edit-layout { display: grid; grid-template-columns: 180px 1fr; gap: var(--space-6); }
  @media (max-width: 640px) { .edit-layout { grid-template-columns: 1fr; } }

  .sidebar { display: flex; flex-direction: column; gap: var(--space-1); }
  .sidebar-link { padding: var(--space-2) var(--space-3); border-radius: var(--radius); color: var(--color-text-muted); text-decoration: none; font-size: 0.875rem; }
  .sidebar-link:hover { background: var(--color-surface); color: var(--color-text); }
  .sidebar-link.active { background: var(--color-surface); color: var(--color-accent); }

  .edit-content h1 { font-size: 1.5rem; margin-bottom: var(--space-6); }

  .section { margin-bottom: var(--space-8); }
  .section h2 { font-size: 1.125rem; margin-bottom: var(--space-3); }

  .data-table { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; }
  .data-row { display: flex; justify-content: space-between; padding: var(--space-2) var(--space-4); border-bottom: 1px solid var(--color-border); font-size: 0.875rem; }
  .data-row:last-child { border-bottom: none; }
  .data-row.total { font-weight: 700; background: color-mix(in srgb, var(--color-accent) 8%, transparent); }

  .mono { font-family: var(--font-mono); }

  .collab-expenses { margin-bottom: var(--space-4); }
  .collab-expenses h3 { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: var(--space-2); }

  .expense-line { display: flex; justify-content: space-between; padding: var(--space-1) 0; font-size: 0.875rem; }
  .expense-right { display: flex; gap: var(--space-3); align-items: center; }
  .receipt { font-size: 0.75rem; color: var(--color-accent); }

  .profit-section { text-align: center; }
  .profit-box { background: var(--color-surface); border: 2px solid var(--color-accent); border-radius: var(--radius-lg); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); }
  .profit-label { font-size: 0.875rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .profit-value { font-size: 2.5rem; font-weight: 700; font-family: var(--font-mono); color: var(--color-success); }
  .profit-value.negative { color: var(--color-error); }
  .profit-formula { font-size: 0.75rem; color: var(--color-text-muted); margin-top: var(--space-2); }

  .collab-payout { margin-bottom: var(--space-4); padding: var(--space-3); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); }
  .payout-header { display: flex; justify-content: space-between; font-size: 0.875rem; margin-bottom: var(--space-2); flex-wrap: wrap; gap: var(--space-2); }
  .payout-line { display: flex; justify-content: space-between; font-size: 0.875rem; padding: var(--space-1) 0; color: var(--color-text-muted); }
  .payout-date { font-size: 0.75rem; }

  .btn-record { display: inline-block; margin-top: var(--space-2); padding: var(--space-1) var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius); color: var(--color-text-muted); text-decoration: none; font-size: 0.75rem; }
  .btn-record:hover { border-color: var(--color-accent); color: var(--color-accent); }
</style>
