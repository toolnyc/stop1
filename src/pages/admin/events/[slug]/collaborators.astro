---
import Admin from '@/layouts/Admin.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { slug } = Astro.params;
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');

const { data: event } = await supabaseAdmin
  .from('events')
  .select('id, title')
  .eq('slug', slug!)
  .single();

if (!event) return Astro.redirect('/admin');

const { data: collaborators } = await supabaseAdmin
  .from('collaborators')
  .select('*')
  .eq('event_id', event.id)
  .order('created_at');

const collabList = collaborators ?? [];
const totalPct = collabList.reduce((sum, c) => sum + Number(c.payout_pct), 0);
const origin = Astro.url.origin;
---
<Admin title={`Collaborators — ${event.title}`}>
  <div class="edit-layout">
    <nav class="sidebar">
      <a href={`/admin/events/${slug}`} class="sidebar-link">Edit</a>
      <a href={`/admin/events/${slug}/rsvps`} class="sidebar-link">RSVPs</a>
      <a href={`/door/${slug}`} class="sidebar-link external" target="_blank">Door</a>
      <a href={`/admin/events/${slug}/budget`} class="sidebar-link">Budget</a>
      <a href={`/admin/events/${slug}/collaborators`} class="sidebar-link active">Collaborators</a>
    </nav>

    <div class="edit-content">
      <h1>Collaborators</h1>

      {error && <div class="alert alert-error">{error}</div>}
      {success && <div class="alert alert-success">{success}</div>}

      <div class:list={['total-pct', { warn: totalPct > 100 }]}>
        Total payout: <span>{totalPct}%</span>
        {totalPct > 100 && <span class="pct-warn"> (exceeds 100%)</span>}
      </div>

      {collabList.length > 0 && (
        <div class="collab-list">
          {collabList.map((c) => (
            <div class="collab-row">
              <div class="collab-info">
                <span class="collab-name">{c.name}</span>
                <span class="collab-email text-muted">{c.email}</span>
              </div>
              <div class="collab-meta">
                <span class="collab-pct mono">{c.payout_pct}%</span>
                <span class={`badge ${c.accepted_at ? 'badge-success' : 'badge-warning'}`}>
                  {c.accepted_at ? 'Accepted' : 'Pending'}
                </span>
                <button
                  class="btn btn-secondary btn-sm copy-link"
                  data-link={`${origin}/collaborate/${c.invite_token}`}
                >
                  Copy Link
                </button>
                <form method="POST" action={`/api/admin/events/${slug}/collaborators/remove`} style="display:inline">
                  <input type="hidden" name="collaborator_id" value={c.id} />
                  <button type="submit" class="btn-icon-remove" title="Remove">&times;</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}

      <form method="POST" action={`/api/admin/events/${slug}/collaborators/add`} class="add-form card">
        <h2>Add Collaborator</h2>
        <div class="form-row">
          <label>
            <span>Name *</span>
            <input type="text" name="name" required placeholder="DJ Name" />
          </label>
          <label>
            <span>Email *</span>
            <input type="email" name="email" required placeholder="dj@example.com" />
          </label>
          <label>
            <span>Payout % *</span>
            <input type="number" name="payout_pct" min="0" max="100" step="0.01" required value="0" />
          </label>
        </div>
        <button type="submit" class="btn btn-primary">Add</button>
      </form>
    </div>
  </div>
</Admin>

<script>
  document.querySelectorAll('.copy-link').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const link = (btn as HTMLElement).dataset.link!;
      await navigator.clipboard.writeText(link);
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = original; }, 2000);
    });
  });
</script>

<style>
  .edit-layout { display: grid; grid-template-columns: 180px 1fr; gap: var(--space-2xl); }
  @media (max-width: 640px) {
    .edit-layout { grid-template-columns: 1fr; gap: var(--space-md); }
    .sidebar { flex-direction: row !important; overflow-x: auto; gap: var(--space-xs) !important; padding-bottom: var(--space-sm); border-bottom: var(--border); }
    .sidebar-link { white-space: nowrap; }
  }

  .sidebar { display: flex; flex-direction: column; gap: var(--space-xs); }
  .sidebar-link { padding: var(--space-sm) var(--space-sm); color: var(--color-muted); text-decoration: none; font-size: 0.875rem; font-weight: var(--weight-medium); transition: background var(--transition), color var(--transition); }
  .sidebar-link:hover { background: var(--color-surface); color: var(--color-fg); }
  .sidebar-link.active { background: var(--color-surface); color: var(--color-accent); }
  .sidebar-link.external::after { content: ' ↗'; opacity: 0.5; }

  .edit-content h1 { font-size: 1.5rem; letter-spacing: var(--tracking-tight); margin-bottom: var(--space-md); }

  .alert { margin-bottom: var(--space-md); }

  .total-pct {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }

  .pct-warn { color: var(--color-warning); font-weight: var(--weight-medium); }

  .collab-list {
    display: flex;
    flex-direction: column;
    border: var(--border);
    overflow: hidden;
    margin-bottom: var(--space-2xl);
  }

  .collab-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-surface);
    gap: var(--space-sm);
    border-bottom: var(--border);
  }

  .collab-row:last-child { border-bottom: none; }

  .collab-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .collab-name { font-weight: var(--weight-medium); }
  .collab-email { font-size: 0.8125rem; }

  .collab-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .collab-pct { font-size: 0.8125rem; color: var(--color-muted); }

  .btn-icon-remove {
    background: transparent;
    border: var(--border-width) solid var(--color-border);
    color: var(--color-error);
    width: 28px;
    height: 28px;
    cursor: pointer;
    font-size: 1.125rem;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--transition), background var(--transition);
  }

  .btn-icon-remove:hover {
    border-color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 12%, transparent);
  }

  .add-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 600px;
  }

  .add-form h2 { font-size: 1.125rem; font-weight: var(--weight-bold); }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: var(--space-sm);
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>
