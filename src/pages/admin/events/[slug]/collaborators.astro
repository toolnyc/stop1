---
import Admin from '@/layouts/Admin.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { slug } = Astro.params;
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');

const { data: event } = await supabaseAdmin
  .from('events')
  .select('id, title')
  .eq('slug', slug!)
  .single();

if (!event) return Astro.redirect('/admin');

const { data: collaborators } = await supabaseAdmin
  .from('collaborators')
  .select('*')
  .eq('event_id', event.id)
  .order('created_at');

const collabList = collaborators ?? [];
const totalPct = collabList.reduce((sum, c) => sum + Number(c.payout_pct), 0);
const origin = Astro.url.origin;
---
<Admin title={`Collaborators — ${event.title}`}>
  <div class="edit-layout">
    <nav class="sidebar">
      <a href={`/admin/events/${slug}`} class="sidebar-link">Edit</a>
      <a href={`/admin/events/${slug}/rsvps`} class="sidebar-link">RSVPs</a>
      <a href={`/door/${slug}`} class="sidebar-link" target="_blank">Door ↗</a>
      <a href={`/admin/events/${slug}/budget`} class="sidebar-link">Budget</a>
      <a href={`/admin/events/${slug}/collaborators`} class="sidebar-link active">Collaborators</a>
    </nav>

    <div class="edit-content">
      <h1>Collaborators</h1>

      {error && <div class="form-error">{error}</div>}
      {success && <div class="form-success">{success}</div>}

      <div class="total-pct" class:list={[{ warn: totalPct > 100 }]}>
        Total payout: {totalPct}%
        {totalPct > 100 && <span class="pct-warn"> (exceeds 100%)</span>}
      </div>

      {collabList.length > 0 && (
        <div class="collab-list">
          {collabList.map((c) => (
            <div class="collab-row">
              <div class="collab-info">
                <span class="collab-name">{c.name}</span>
                <span class="collab-email">{c.email}</span>
              </div>
              <div class="collab-meta">
                <span class="collab-pct">{c.payout_pct}%</span>
                <span class={`collab-status ${c.accepted_at ? 'accepted' : 'pending'}`}>
                  {c.accepted_at ? 'Accepted' : 'Pending'}
                </span>
                <button
                  class="copy-link"
                  data-link={`${origin}/collaborate/${c.invite_token}`}
                  title="Copy invite link"
                >
                  Copy Link
                </button>
                <form method="POST" action={`/api/admin/events/${slug}/collaborators/remove`} style="display:inline">
                  <input type="hidden" name="collaborator_id" value={c.id} />
                  <button type="submit" class="btn-remove" title="Remove collaborator">×</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}

      <form method="POST" action={`/api/admin/events/${slug}/collaborators/add`} class="add-form">
        <h2>Add Collaborator</h2>
        <div class="form-row">
          <label>
            <span>Name *</span>
            <input type="text" name="name" required />
          </label>
          <label>
            <span>Email *</span>
            <input type="email" name="email" required />
          </label>
          <label>
            <span>Payout % *</span>
            <input type="number" name="payout_pct" min="0" max="100" step="0.01" required value="0" />
          </label>
        </div>
        <button type="submit">Add</button>
      </form>
    </div>
  </div>
</Admin>

<script>
  document.querySelectorAll('.copy-link').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const link = (btn as HTMLElement).dataset.link!;
      await navigator.clipboard.writeText(link);
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = original; }, 2000);
    });
  });
</script>

<style>
  .edit-layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-6);
  }

  @media (max-width: 640px) {
    .edit-layout { grid-template-columns: 1fr; }
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .sidebar-link {
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .sidebar-link:hover { background: var(--color-surface); color: var(--color-text); }
  .sidebar-link.active { background: var(--color-surface); color: var(--color-accent); }

  .edit-content h1 { font-size: 1.5rem; margin-bottom: var(--space-4); }

  .form-error {
    background: color-mix(in srgb, var(--color-error) 15%, transparent);
    border: 1px solid var(--color-error);
    color: var(--color-error);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    font-size: 0.875rem;
    margin-bottom: var(--space-4);
  }

  .form-success {
    background: color-mix(in srgb, var(--color-success) 15%, transparent);
    border: 1px solid var(--color-success);
    color: var(--color-success);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    font-size: 0.875rem;
    margin-bottom: var(--space-4);
  }

  .total-pct {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .pct-warn { color: var(--color-warning); }

  .collab-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: var(--space-6);
  }

  .collab-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    gap: var(--space-3);
  }

  .collab-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .collab-name { font-weight: 600; }
  .collab-email { font-size: 0.875rem; color: var(--color-text-muted); }

  .collab-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  .collab-pct { color: var(--color-text-muted); }
  .collab-status.accepted { color: var(--color-success); }
  .collab-status.pending { color: var(--color-warning); }

  .copy-link {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius);
    font-size: 0.75rem;
    cursor: pointer;
  }

  .copy-link:hover { border-color: var(--color-text-muted); color: var(--color-text); }

  .btn-remove {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-error);
    width: 28px;
    height: 28px;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 1rem;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-remove:hover { border-color: var(--color-error); background: color-mix(in srgb, var(--color-error) 15%, transparent); }

  .add-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 600px;
  }

  .add-form h2 { font-size: 1.125rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: var(--space-3);
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
  }

  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  label span { font-size: 0.875rem; color: var(--color-text-muted); }

  input {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 1rem;
  }

  input:focus { outline: none; border-color: var(--color-accent); }

  .add-form > button {
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius);
    font-weight: 600;
    cursor: pointer;
    align-self: flex-start;
  }
</style>
