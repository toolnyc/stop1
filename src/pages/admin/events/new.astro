---
import Admin from '@/layouts/Admin.astro';

const error = Astro.url.searchParams.get('error');
const fieldError = Astro.url.searchParams.get('field_error');
---

<Admin title="New Event — Stop One Admin">
  <h1 class="page-title">New Event</h1>

  {error && <div class="alert alert-error">{error}</div>}
  {fieldError && <div class="alert alert-error">{fieldError}</div>}

  <form
    method="POST"
    action="/api/admin/events/create"
    enctype="multipart/form-data"
    class="event-form"
    id="event-form"
  >
    <label>
      <span>Title *</span>
      <input
        type="text"
        name="title"
        required
        id="title-input"
        placeholder="e.g. Stop One Vol. 3"
      />
    </label>

    <label>
      <span>Slug *</span>
      <input
        type="text"
        name="slug"
        required
        id="slug-input"
        pattern="[a-z0-9-]+"
        title="Lowercase letters, numbers, and hyphens only"
        placeholder="auto-generated"
      />
      <small>Auto-generated from title. Lowercase letters, numbers, hyphens.</small>
    </label>

    <div class="flyer-section">
      <span class="field-label">Flyer</span>
      <div id="flyer-preview">
        <label class="flyer-drop" id="flyer-drop">
          <span class="flyer-drop-text">Drop flyer image here or click to upload</span>
          <small>JPEG or PNG, max 5MB. Auto-compressed to ~1200px wide.</small>
          <input type="file" name="flyer" accept="image/*" class="sr-only" id="flyer-input" />
        </label>
      </div>
      <div id="flyer-status" class="flyer-status"></div>
    </div>

    <div class="form-row">
      <label>
        <span>Start Date/Time *</span>
        <input type="datetime-local" name="date" required />
      </label>
      <label>
        <span>End Date/Time</span>
        <input type="datetime-local" name="time_end" />
      </label>
    </div>

    <label>
      <span>Venue Name</span>
      <input type="text" name="venue_name" placeholder="e.g. The Basement" />
    </label>

    <label>
      <span>Venue Address</span>
      <input type="text" name="venue_address" placeholder="e.g. 123 Main St" />
    </label>

    <label>
      <span>Description</span>
      <textarea name="description" rows="4" placeholder="What's this event about?"></textarea>
    </label>

    <div class="form-row">
      <label>
        <span>Door Price *</span>
        <input type="number" name="door_price" min="0" step="0.01" required value="0" />
      </label>
      <label>
        <span>Capacity</span>
        <input type="number" name="capacity" min="0" placeholder="Unlimited" />
      </label>
    </div>

    <label>
      <span>Door PIN *</span>
      <input
        type="text"
        name="door_pin"
        required
        inputmode="numeric"
        pattern="[0-9]+"
        title="Numbers only"
        placeholder="e.g. 1234"
      />
      <small>Used for door check-in authentication.</small>
    </label>

    <label>
      <span>Status</span>
      <select name="status">
        <option value="draft">Draft</option>
        <option value="published">Published</option>
      </select>
    </label>

    <button type="submit" class="btn btn-primary" id="submit-btn">Create Event</button>
  </form>
</Admin>

<script>
  const MAX_WIDTH = 1200;
  const JPEG_QUALITY = 0.8;

  const titleInput = document.getElementById('title-input') as HTMLInputElement;
  const slugInput = document.getElementById('slug-input') as HTMLInputElement;
  const flyerInput = document.getElementById('flyer-input') as HTMLInputElement;
  const flyerPreview = document.getElementById('flyer-preview')!;
  const flyerStatus = document.getElementById('flyer-status')!;
  const form = document.getElementById('event-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  let slugManuallyEdited = false;
  let compressedFile: File | null = null;

  slugInput?.addEventListener('input', () => {
    slugManuallyEdited = true;
  });

  titleInput?.addEventListener('input', () => {
    if (!slugManuallyEdited) {
      slugInput.value = titleInput.value
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '');
    }
  });

  async function compressImage(file: File): Promise<File> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => {
        let { width, height } = img;
        if (width > MAX_WIDTH) {
          height = Math.round(height * (MAX_WIDTH / width));
          width = MAX_WIDTH;
        }
        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d')!;
        ctx.drawImage(img, 0, 0, width, height);
        canvas.toBlob(
          (blob) => {
            if (!blob) return reject(new Error('Compression failed'));
            const compressed = new File([blob], file.name.replace(/\.\w+$/, '.jpg'), {
              type: 'image/jpeg',
            });
            resolve(compressed);
          },
          'image/jpeg',
          JPEG_QUALITY,
        );
      };
      img.onerror = () => reject(new Error('Failed to load image'));
      img.src = URL.createObjectURL(file);
    });
  }

  function showPreview(src: string, sizeText: string) {
    flyerPreview.innerHTML = `
      <img src="${src}" alt="Flyer preview" class="flyer-thumb" />
      <div class="flyer-actions">
        <label class="btn btn-secondary btn-sm flyer-change-btn">
          Replace
          <input type="file" name="flyer" accept="image/*" class="sr-only" id="flyer-input" />
        </label>
        <button type="button" class="btn btn-danger btn-sm" id="flyer-remove">Remove</button>
      </div>
    `;
    flyerStatus.textContent = sizeText;

    const newInput = document.getElementById('flyer-input') as HTMLInputElement;
    newInput.addEventListener('change', handleFileSelect);
    document.getElementById('flyer-remove')!.addEventListener('click', handleRemove);
  }

  function showDropZone() {
    flyerPreview.innerHTML = `
      <label class="flyer-drop" id="flyer-drop">
        <span class="flyer-drop-text">Drop flyer image here or click to upload</span>
        <small>JPEG or PNG, max 5MB. Auto-compressed to ~1200px wide.</small>
        <input type="file" name="flyer" accept="image/*" class="sr-only" id="flyer-input" />
      </label>
    `;
    flyerStatus.textContent = '';
    const newInput = document.getElementById('flyer-input') as HTMLInputElement;
    newInput.addEventListener('change', handleFileSelect);
    setupDragDrop();
  }

  async function handleFileSelect(e: Event) {
    const input = e.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;

    if (!file.type.startsWith('image/')) {
      flyerStatus.textContent = 'Please select an image file.';
      return;
    }

    flyerStatus.textContent = 'Compressing...';
    submitBtn.disabled = true;

    try {
      const origSize = (file.size / 1024).toFixed(0);
      compressedFile = await compressImage(file);
      const newSize = (compressedFile.size / 1024).toFixed(0);
      const previewUrl = URL.createObjectURL(compressedFile);
      showPreview(previewUrl, `${origSize}KB → ${newSize}KB`);
    } catch {
      flyerStatus.textContent = 'Failed to compress image.';
    } finally {
      submitBtn.disabled = false;
    }
  }

  function handleRemove() {
    compressedFile = null;
    showDropZone();
  }

  function setupDragDrop() {
    const drop = document.getElementById('flyer-drop');
    if (!drop) return;
    drop.addEventListener('dragover', (e) => {
      e.preventDefault();
      drop.classList.add('drag-over');
    });
    drop.addEventListener('dragleave', () => drop.classList.remove('drag-over'));
    drop.addEventListener('drop', (e) => {
      e.preventDefault();
      drop.classList.remove('drag-over');
      const file = (e as DragEvent).dataTransfer?.files[0];
      if (file) {
        const input = drop.querySelector('input[type="file"]') as HTMLInputElement;
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
      }
    });
  }

  // Inject compressed file into form on submit
  form.addEventListener('submit', (e) => {
    if (compressedFile) {
      e.preventDefault();
      const formData = new FormData(form);
      formData.set('flyer', compressedFile);
      fetch(form.action, { method: 'POST', body: formData }).then((res) => {
        if (res.redirected) {
          window.location.href = res.url;
        }
      });
    }
  });

  // Init
  flyerInput?.addEventListener('change', handleFileSelect);
  setupDragDrop();
</script>

<style>
  .page-title {
    font-size: 1.5rem;
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-lg);
  }

  .event-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 600px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .alert {
    margin-bottom: var(--space-md);
  }

  /* Flyer upload */
  .flyer-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .field-label {
    font-size: 0.8125rem;
    font-weight: var(--weight-medium);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
  }

  .flyer-thumb {
    width: 100%;
    max-width: 300px;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: var(--border);
  }

  .flyer-actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .flyer-change-btn {
    cursor: pointer;
  }

  .flyer-status {
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>

<style is:global>
  .flyer-drop {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: var(--space-2xl) var(--space-lg);
    border: 2px dashed var(--color-border);
    cursor: pointer;
    text-align: center;
    transition:
      border-color var(--duration-fast) ease,
      background var(--duration-fast) ease;
  }

  .flyer-drop:hover,
  .flyer-drop.drag-over {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .flyer-drop-text {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-weight: var(--weight-medium);
  }

  .flyer-drop small {
    font-size: 0.75rem;
    color: var(--color-faint);
  }
</style>
