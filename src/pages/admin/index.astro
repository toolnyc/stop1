---
import Admin from '@/layouts/Admin.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

// Fetch all events with RSVP counts
const { data: events, error } = await supabaseAdmin
  .from('events')
  .select('*, rsvps(count)')
  .order('date', { ascending: false });

if (error) {
  console.error('Failed to fetch events:', error);
}

const eventList = events ?? [];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function statusBadge(status: string) {
  switch (status) {
    case 'published': return 'badge-success';
    case 'draft': return 'badge-warning';
    default: return 'badge-muted';
  }
}
---
<Admin title="Events — Stop One Admin">
  <div class="dashboard-header">
    <h1>Events</h1>
    <a href="/admin/events/new" class="btn btn-primary btn-sm">New Event</a>
  </div>

  {eventList.length === 0 ? (
    <div class="empty-state">
      <p>No events yet.</p>
      <p class="text-muted">Create your first event to get started.</p>
    </div>
  ) : (
    <div class="event-list">
      {eventList.map((event) => {
        const rsvpCount = (event.rsvps as unknown as { count: number }[])?.[0]?.count ?? 0;
        return (
          <a href={`/admin/events/${event.slug}`} class="event-row">
            <div class="event-info">
              <span class="event-title">{event.title}</span>
              <span class="event-date">{formatDate(event.date)}</span>
            </div>
            <div class="event-meta">
              <span class="rsvp-count mono">{rsvpCount}</span>
              <span class={`badge ${statusBadge(event.status)}`}>{event.status}</span>
            </div>
          </a>
        );
      })}
    </div>
  )}
</Admin>

<style>
  .dashboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
  }

  .dashboard-header h1 {
    font-size: 1.5rem;
    letter-spacing: var(--tracking-tight);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-4xl) 0;
  }

  .event-list {
    display: flex;
    flex-direction: column;
    border: var(--border);
    overflow: hidden;
  }

  .event-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-surface);
    text-decoration: none;
    color: var(--color-fg);
    transition: background var(--transition);
    border-bottom: var(--border);
  }

  .event-row:last-child {
    border-bottom: none;
  }

  .event-row:hover {
    background: var(--color-bg);
  }

  .event-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .event-title {
    font-weight: var(--weight-medium);
  }

  .event-date {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .event-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: 0.875rem;
  }

  .rsvp-count {
    color: var(--color-muted);
    font-size: 0.8125rem;
  }
</style>
