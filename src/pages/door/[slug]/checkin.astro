---
import Base from '@/layouts/Base.astro';
import { supabaseAdmin } from '@/lib/supabase';
import { stripe } from '@/lib/stripe';
import { normalizePhone } from '@/lib/phone';
import { getEffectivePrice } from '@/lib/pricing';
import { EVENT_TIMEZONE } from '@/lib/constants';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { slug } = Astro.params;

const { data: event } = await supabaseAdmin
  .from('events')
  .select('id, title, door_price, early_price, early_cutoff, capacity')
  .eq('slug', slug!)
  .single();

if (!event) return new Response(null, { status: 404 });

const { price: effectivePrice, isEarly } = getEffectivePrice(event);
const cutoffDisplay =
  isEarly && event.early_cutoff
    ? new Intl.DateTimeFormat('en-US', {
        timeZone: EVENT_TIMEZONE,
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      }).format(new Date(event.early_cutoff))
    : null;

/* ── Handle Stripe Checkout return ── */
let checkoutFlash = '';
const sessionId = Astro.url.searchParams.get('session_id');
if (sessionId && stripe) {
  try {
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    if (session.payment_status === 'paid') {
      const meta = session.metadata || {};
      const rsvpId = meta.rsvp_id || Astro.url.searchParams.get('rsvp_id');
      const walkinName = meta.walkin_name || Astro.url.searchParams.get('walkin_name');
      const walkinPhone = meta.walkin_phone || Astro.url.searchParams.get('walkin_phone');
      const checkInPrimary =
        (meta.check_in_primary ?? Astro.url.searchParams.get('check_in_primary') ?? '1') !== '0';
      const checkInGuests =
        parseInt(
          meta.check_in_guests ?? Astro.url.searchParams.get('check_in_guests') ?? '0',
          10,
        ) || 0;

      // Prevent double-processing
      const { count: existingCount } = await supabaseAdmin
        .from('door_payments')
        .select('id', { count: 'exact', head: true })
        .eq('stripe_payment_intent_id', session.payment_intent as string);

      if (!existingCount || existingCount === 0) {
        const totalAmount = Number(session.amount_total ?? 0) / 100;

        if (rsvpId) {
          // Existing RSVP: record payment + mark party arrival
          await supabaseAdmin.from('door_payments').insert({
            event_id: event.id,
            rsvp_id: rsvpId,
            amount: totalAmount,
            method: 'card' as const,
            stripe_payment_intent_id: session.payment_intent as string,
          });

          const { data: rsvp } = await supabaseAdmin
            .from('rsvps')
            .select('arrived_at, plus_ones_arrived')
            .eq('id', rsvpId)
            .eq('event_id', event.id)
            .single();

          if (rsvp) {
            const updates: Record<string, unknown> = {};
            if (checkInPrimary && !rsvp.arrived_at) {
              updates.arrived_at = new Date().toISOString();
            }
            if (checkInGuests > 0) {
              updates.plus_ones_arrived = rsvp.plus_ones_arrived + checkInGuests;
            }
            if (Object.keys(updates).length > 0) {
              await supabaseAdmin
                .from('rsvps')
                .update(updates)
                .eq('id', rsvpId)
                .eq('event_id', event.id);
            }
          }
          checkoutFlash = 'paid';
        } else if (walkinName) {
          // Walk-in: create RSVP + record payment
          const phone = walkinPhone ? normalizePhone(walkinPhone) : null;
          const { data: newRsvp } = await supabaseAdmin
            .from('rsvps')
            .insert({
              event_id: event.id,
              name: walkinName.trim(),
              email: null,
              phone,
              sms_opt_in: !!phone,
              walk_in: true,
              arrived_at: new Date().toISOString(),
            })
            .select('id')
            .single();

          await supabaseAdmin.from('door_payments').insert({
            event_id: event.id,
            rsvp_id: newRsvp?.id || null,
            amount: totalAmount,
            method: 'card' as const,
            stripe_payment_intent_id: session.payment_intent as string,
            name: walkinName.trim(),
          });
          checkoutFlash = 'paid';
        }
      } else {
        checkoutFlash = 'paid';
      }
    }
  } catch {
    // Session retrieval failed — ignore, user can retry
  }
}

const { count: arrivedCount } = await supabaseAdmin
  .from('rsvps')
  .select('id', { count: 'exact', head: true })
  .eq('event_id', event.id)
  .not('arrived_at', 'is', null);

const capacity = event.capacity ?? null;
const arrived = arrivedCount ?? 0;
const atCapacity = capacity !== null && arrived >= capacity;
const nearCapacity = capacity !== null && !atCapacity && arrived >= capacity * 0.9;
---

<Base title={`Check-in — ${event.title}`}>
  <main class="checkin-page dark-ctx">
    {
      checkoutFlash === 'paid' && (
        <div class="checkout-flash" id="checkout-flash">
          <span class="done-check" style="font-size:1.25rem">
            &#10003;
          </span>
          Card payment confirmed
        </div>
      )
    }
    <header class="checkin-header">
      <h1>{event.title}</h1>
      <span
        class={`arrived-badge ${atCapacity ? 'at-capacity' : nearCapacity ? 'near-capacity' : ''}`}
        id="arrived-count"
      >
        {arrived}{capacity !== null ? `/${capacity}` : ''} in
      </span>
      {atCapacity && <span class="capacity-warn">AT CAPACITY</span>}
      {nearCapacity && <span class="capacity-warn capacity-near">NEAR CAPACITY</span>}
      {
        effectivePrice === 0 ? (
          <span class="price-badge price-free">FREE</span>
        ) : (
          <span class="price-badge">${effectivePrice}</span>
        )
      }
      {cutoffDisplay && <span class="price-note">until {cutoffDisplay}</span>}
    </header>

    <div class="search-wrap">
      <svg class="search-icon" viewBox="0 0 20 20" fill="currentColor" width="18" height="18"
        ><path
          fill-rule="evenodd"
          d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z"
          clip-rule="evenodd"></path></svg
      >
      <input
        type="text"
        id="search-input"
        placeholder="Search name or phone..."
        autofocus
        class="search-input"
      />
    </div>

    <div id="results" class="results"></div>

    <button id="walkin-toggle" class="walkin-toggle">Not on list? Add walk-in</button>

    <a href={`/door/${slug}/summary`} class="summary-link">View Summary</a>
  </main>

  <!-- Arrival payment overlay (existing RSVP guests) -->
  <div id="arrive-overlay" class="walkin-overlay" style="display:none">
    <div class="walkin-sheet">
      <button id="arrive-close" class="walkin-close" aria-label="Close">&times;</button>

      <!-- Payment step -->
      <div class="walkin-step" id="arrive-step-pay">
        <h2 class="walkin-step-title" id="arrive-guest-name"></h2>
        <p class="arrive-subtitle" id="arrive-subtitle"></p>

        <!-- Party member checklist (shown for parties of 2+) -->
        <div id="arrive-party-list" class="party-list" style="display:none"></div>

        <div id="arrive-pay-buttons" class="pay-buttons">
          <button id="arrive-btn-cash" class="btn btn-pay btn-block">
            <span class="pay-icon">$</span>
            Cash &mdash; <span id="arrive-cash-label"></span>
          </button>
          <button id="arrive-btn-card" class="btn btn-pay btn-block">
            <span class="pay-icon">&#9909;</span>
            Card &mdash; <span id="arrive-card-label"></span>
          </button>
        </div>

        <div id="arrive-processing" class="pay-processing" style="display:none">
          <div class="spinner"></div>
          <p>Processing...</p>
        </div>
      </div>

      <!-- Done step -->
      <div class="walkin-step" id="arrive-step-done" style="display:none">
        <div class="done-check">&#10003;</div>
        <h2 class="walkin-step-title">Checked In!</h2>
        <p id="arrive-done-name" class="done-subtitle"></p>
        <button id="arrive-btn-done" class="btn btn-primary btn-block">Done</button>
      </div>
    </div>
  </div>

  <!-- Walk-in wizard overlay -->
  <div id="walkin-overlay" class="walkin-overlay" style="display:none">
    <div class="walkin-sheet">
      <button id="walkin-close" class="walkin-close" aria-label="Close">&times;</button>

      <!-- Step 1: Name -->
      <div class="walkin-step" id="step-name">
        <h2 class="walkin-step-title">Guest Name</h2>
        <input
          type="text"
          id="walkin-name"
          placeholder="Full name"
          class="walkin-input"
          autocomplete="off"
          enterkeyhint="next"
        />
        <button id="btn-to-phone" class="btn btn-primary btn-block" disabled>Next</button>
      </div>

      <!-- Step 2: Phone -->
      <div class="walkin-step" id="step-phone" style="display:none">
        <h2 class="walkin-step-title">Phone Number</h2>
        <input
          type="tel"
          id="walkin-phone"
          placeholder="(555) 123-4567"
          class="walkin-input"
          autocomplete="off"
          enterkeyhint="next"
        />
        <button id="btn-to-pay" class="btn btn-primary btn-block">Next</button>
        <button id="btn-skip-phone" class="btn btn-ghost btn-block">Skip</button>
      </div>

      <!-- Step 3: Payment -->
      <div class="walkin-step" id="step-pay" style="display:none">
        <h2 class="walkin-step-title">
          Payment &mdash; <span id="pay-price"></span>
        </h2>
        <div id="pay-buttons" class="pay-buttons">
          <button id="btn-cash" class="btn btn-pay btn-block">
            <span class="pay-icon">$</span>
            Cash
          </button>
          <button id="btn-card" class="btn btn-pay btn-block">
            <span class="pay-icon">&#9909;</span>
            Card
          </button>
        </div>

        <div id="pay-processing" class="pay-processing" style="display:none">
          <div class="spinner"></div>
          <p>Processing...</p>
        </div>
      </div>

      <!-- Step 4: Done -->
      <div class="walkin-step" id="step-done" style="display:none">
        <div class="done-check">&#10003;</div>
        <h2 class="walkin-step-title">Added!</h2>
        <p id="done-name" class="done-subtitle"></p>
        <button id="btn-done" class="btn btn-primary btn-block">Done</button>
      </div>
    </div>
  </div>
</Base>

<script define:vars={{ slug, doorPrice: effectivePrice, eventCapacity: capacity }}>
  const unitPrice = Number(doorPrice);
  const fmt = (n) => `$${Number(n).toFixed(0)}`;

  /* ── Redirect to Stripe Checkout ── */
  async function redirectToCheckout(body) {
    const res = await fetch(`/api/door/${slug}/payment/create-checkout`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!res.ok) throw new Error('Could not start card payment');
    const { url } = await res.json();
    window.location.href = url;
  }

  /* ── Auto-dismiss checkout flash ── */
  const flash = document.getElementById('checkout-flash');
  if (flash) {
    const cleanUrl = window.location.pathname;
    history.replaceState(null, '', cleanUrl);
    setTimeout(() => {
      flash.style.display = 'none';
    }, 4000);
  }

  /* ── Search ── */
  const searchInput = document.getElementById('search-input');
  const results = document.getElementById('results');
  const arrivedCountEl = document.getElementById('arrived-count');
  let debounceTimer;
  let localArrivedCount = parseInt(arrivedCountEl.textContent);

  searchInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doSearch, 150);
  });

  doSearch();

  results.addEventListener('click', (e) => {
    const btn = e.target.closest('.arrive-btn');
    if (btn) {
      openArrivePayment(JSON.parse(btn.dataset.guest));
    }
  });

  async function doSearch() {
    const q = searchInput.value.trim();
    const res = await fetch(`/api/door/${slug}/search?q=${encodeURIComponent(q)}`);
    const guests = await res.json();
    results.innerHTML = guests.map(renderGuestCard).join('');
  }

  function renderGuestCard(g) {
    const plusCount = g.plus_one_count || 0;
    const partySize = 1 + plusCount;
    const arrivedTotal = (g.arrived_at ? 1 : 0) + (g.plus_ones_arrived || 0);
    const fullyArrived = arrivedTotal === partySize;

    let statusHtml;
    if (fullyArrived) {
      statusHtml = '<span class="guest-badge-arrived">[Arrived]</span>';
    } else if (arrivedTotal > 0) {
      statusHtml = `
        <span class="guest-badge-partial">${arrivedTotal}/${partySize} in</span>
        <button class="btn btn-primary btn-sm arrive-btn" data-guest='${esc(JSON.stringify(g))}'>More In</button>
      `;
    } else {
      statusHtml = `<button class="btn btn-primary btn-sm arrive-btn" data-guest='${esc(JSON.stringify(g))}'>Mark Arrived</button>`;
    }

    const partyTag =
      plusCount > 0
        ? `<span class="guest-party">+${plusCount} guest${plusCount > 1 ? 's' : ''}</span>`
        : '';

    return `
      <div class="guest-card ${fullyArrived ? 'arrived' : arrivedTotal > 0 ? 'partial' : ''}" data-id="${esc(g.id)}">
        <div class="guest-info">
          <span class="guest-name">${esc(g.name)}${partyTag}</span>
          <span class="guest-phone">${g.phone && !g.phone.startsWith('+0000000') ? esc(g.phone) : ''}</span>
        </div>
        <div class="guest-actions">${statusHtml}</div>
      </div>
    `;
  }

  function esc(s) {
    const d = document.createElement('div');
    d.textContent = s || '';
    return d.innerHTML;
  }

  /* ── Arrival overlay ── */
  const arriveOverlay = document.getElementById('arrive-overlay');
  let currentRsvp = null;
  let checkedSlots = []; // { label, isGuest, checked }

  async function openArrivePayment(g) {
    currentRsvp = g;
    checkedSlots = [];

    if (!g.arrived_at) {
      checkedSlots.push({ label: g.name, isGuest: false, checked: true });
    }
    const alreadyIn = g.plus_ones_arrived || 0;
    for (let i = alreadyIn + 1; i <= (g.plus_one_count || 0); i++) {
      checkedSlots.push({ label: `Guest ${i}`, isGuest: true, checked: true });
    }

    // Free entry: skip payment overlay entirely, just mark arrived
    if (unitPrice === 0) {
      const selected = checkedSlots.filter((s) => s.checked);
      if (!selected.length) return;
      try {
        const checkInPrimary = selected.some((s) => !s.isGuest);
        const checkInGuests = selected.filter((s) => s.isGuest).length;
        const res = await fetch(`/api/door/${slug}/arrive-party`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            rsvpId: g.id,
            checkInPrimary,
            checkInGuests,
          }),
        });
        if (!res.ok) {
          // Fallback to simple arrive
          await fetch(`/api/door/${slug}/arrive`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rsvpId: g.id }),
          });
        }
        arriveSuccess(selected);
        // Show done overlay briefly
        document.getElementById('arrive-guest-name').textContent = g.name;
        document.getElementById('arrive-step-pay').style.display = 'none';
        document.getElementById('arrive-step-done').style.display = 'flex';
        document.getElementById('arrive-done-name').textContent = selected
          .map((s) => s.label)
          .join(', ');
        arriveOverlay.style.display = 'flex';
      } catch (err) {
        alert(err.message || 'Something went wrong');
      }
      return;
    }

    document.getElementById('arrive-guest-name').textContent = g.name;

    const partyList = document.getElementById('arrive-party-list');
    if (checkedSlots.length > 1) {
      partyList.style.display = 'flex';
      renderPartyList();
    } else {
      partyList.style.display = 'none';
    }

    updateArriveButtons();

    document.getElementById('arrive-step-pay').style.display = 'flex';
    document.getElementById('arrive-step-done').style.display = 'none';
    document.getElementById('arrive-pay-buttons').style.display = 'flex';
    document.getElementById('arrive-processing').style.display = 'none';
    arriveOverlay.style.display = 'flex';
  }

  function renderPartyList() {
    const partyList = document.getElementById('arrive-party-list');
    partyList.innerHTML = checkedSlots
      .map(
        (slot, i) => `
      <label class="party-slot">
        <input type="checkbox" ${slot.checked ? 'checked' : ''} onchange="toggleSlot(${i}, this.checked)" />
        <span>${esc(slot.label)}</span>
      </label>
    `,
      )
      .join('');
  }

  window.toggleSlot = function (i, checked) {
    checkedSlots[i].checked = checked;
    updateArriveButtons();
  };

  function updateArriveButtons() {
    const count = checkedSlots.filter((s) => s.checked).length;
    const plusCount = currentRsvp.plus_one_count || 0;
    const alreadyIn = (currentRsvp.arrived_at ? 1 : 0) + (currentRsvp.plus_ones_arrived || 0);
    const remaining = 1 + plusCount - alreadyIn;

    document.getElementById('arrive-subtitle').textContent =
      plusCount > 0
        ? `Select who's arriving now (${count} of ${remaining} remaining)`
        : `Payment — ${fmt(unitPrice)}`;

    const price = fmt(count * unitPrice);
    document.getElementById('arrive-cash-label').textContent = price;
    document.getElementById('arrive-card-label').textContent = price;

    document.querySelectorAll('#arrive-pay-buttons .btn-pay').forEach((b) => {
      b.disabled = count === 0;
    });
  }

  document.getElementById('arrive-close').addEventListener('click', () => {
    arriveOverlay.style.display = 'none';
  });
  arriveOverlay.addEventListener('click', (e) => {
    if (e.target === arriveOverlay) arriveOverlay.style.display = 'none';
  });

  document.getElementById('arrive-btn-cash').addEventListener('click', async () => {
    const selected = checkedSlots.filter((s) => s.checked);
    if (!selected.length) return;

    document.getElementById('arrive-pay-buttons').style.display = 'none';
    document.getElementById('arrive-processing').style.display = 'flex';

    const checkInPrimary = selected.some((s) => !s.isGuest);
    const checkInGuests = selected.filter((s) => s.isGuest).length;

    try {
      const res = await fetch(`/api/door/${slug}/payment/cash`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          rsvpId: currentRsvp.id,
          checkInPrimary,
          checkInGuests,
        }),
      });
      if (!res.ok) throw new Error('Cash payment failed');
      arriveSuccess(selected);
    } catch (err) {
      alert(err.message || 'Something went wrong');
      document.getElementById('arrive-processing').style.display = 'none';
      document.getElementById('arrive-pay-buttons').style.display = 'flex';
    }
  });

  document.getElementById('arrive-btn-card').addEventListener('click', async () => {
    const selected = checkedSlots.filter((s) => s.checked);
    if (!selected.length) return;

    document.getElementById('arrive-pay-buttons').style.display = 'none';
    document.getElementById('arrive-processing').style.display = 'flex';

    try {
      await redirectToCheckout({
        rsvpId: currentRsvp.id,
        checkInPrimary: selected.some((s) => !s.isGuest),
        checkInGuests: selected.filter((s) => s.isGuest).length,
      });
    } catch (err) {
      alert(err.message || 'Something went wrong');
      document.getElementById('arrive-processing').style.display = 'none';
      document.getElementById('arrive-pay-buttons').style.display = 'flex';
    }
  });

  function arriveSuccess(selected) {
    // Update the arrived-count badge for primary arrivals
    const primaryArriving = selected.filter((s) => !s.isGuest).length;
    if (primaryArriving > 0 && !currentRsvp.arrived_at) {
      localArrivedCount += primaryArriving;
      arrivedCountEl.textContent = localArrivedCount + ' in';
    }

    // Patch the guest card in-place
    const card = document.querySelector(`.guest-card[data-id="${currentRsvp.id}"]`);
    if (card) {
      const updatedRsvp = {
        ...currentRsvp,
        arrived_at: selected.some((s) => !s.isGuest)
          ? new Date().toISOString()
          : currentRsvp.arrived_at,
        plus_ones_arrived:
          (currentRsvp.plus_ones_arrived || 0) + selected.filter((s) => s.isGuest).length,
      };
      card.outerHTML = renderGuestCard(updatedRsvp);
    }

    document.getElementById('arrive-done-name').textContent = selected
      .map((s) => s.label)
      .join(', ');
    document.getElementById('arrive-step-pay').style.display = 'none';
    document.getElementById('arrive-step-done').style.display = 'flex';
  }

  document.getElementById('arrive-btn-done').addEventListener('click', () => {
    arriveOverlay.style.display = 'none';
  });

  /* ── Walk-in wizard ── */
  const overlay = document.getElementById('walkin-overlay');
  const walkinName = document.getElementById('walkin-name');
  const walkinPhone = document.getElementById('walkin-phone');
  const steps = {
    name: document.getElementById('step-name'),
    phone: document.getElementById('step-phone'),
    pay: document.getElementById('step-pay'),
    done: document.getElementById('step-done'),
  };

  function showStep(key) {
    Object.values(steps).forEach((s) => (s.style.display = 'none'));
    steps[key].style.display = 'flex';
  }

  function openWizard() {
    walkinName.value = '';
    walkinPhone.value = '';
    showStep('name');
    overlay.style.display = 'flex';
    document.getElementById('pay-buttons').style.display = 'flex';
    document.getElementById('pay-processing').style.display = 'none';
    setTimeout(() => walkinName.focus(), 50);
  }

  function closeWizard() {
    overlay.style.display = 'none';
  }

  document.getElementById('walkin-toggle').addEventListener('click', openWizard);
  document.getElementById('walkin-close').addEventListener('click', closeWizard);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeWizard();
  });

  const btnToPhone = document.getElementById('btn-to-phone');
  walkinName.addEventListener('input', () => {
    btnToPhone.disabled = !walkinName.value.trim();
  });
  walkinName.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && walkinName.value.trim()) goToPhone();
  });
  btnToPhone.addEventListener('click', goToPhone);

  function goToPhone() {
    showStep('phone');
    setTimeout(() => walkinPhone.focus(), 50);
  }

  document.getElementById('btn-to-pay').addEventListener('click', goToPay);
  document.getElementById('btn-skip-phone').addEventListener('click', () => {
    walkinPhone.value = '';
    goToPay();
  });
  walkinPhone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') goToPay();
  });

  async function goToPay() {
    // Free entry: skip payment, create walk-in directly
    if (unitPrice === 0) {
      showStep('pay');
      showProcessing();
      try {
        const res = await fetch(`/api/door/${slug}/arrive`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: walkinName.value.trim(),
            phone: walkinPhone.value.trim() || undefined,
          }),
        });
        if (!res.ok) throw new Error('Failed to add walk-in');
        localArrivedCount++;
        arrivedCountEl.textContent = localArrivedCount + ' in';
        showDone();
      } catch (err) {
        alert(err.message || 'Something went wrong');
        hideProcessing();
      }
      return;
    }
    document.getElementById('pay-price').textContent = fmt(unitPrice);
    showStep('pay');
  }

  document.getElementById('btn-cash').addEventListener('click', async () => {
    showProcessing();
    try {
      const payRes = await fetch(`/api/door/${slug}/payment/cash`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: walkinName.value.trim(),
          phone: walkinPhone.value.trim() || undefined,
        }),
      });
      if (!payRes.ok) throw new Error('Cash payment failed');

      localArrivedCount++;
      arrivedCountEl.textContent = localArrivedCount + ' in';
      showDone();
    } catch (err) {
      alert(err.message || 'Something went wrong');
      hideProcessing();
    }
  });

  document.getElementById('btn-card').addEventListener('click', async () => {
    showProcessing();
    try {
      await redirectToCheckout({
        name: walkinName.value.trim(),
        phone: walkinPhone.value.trim() || undefined,
      });
    } catch (err) {
      alert(err.message || 'Something went wrong');
      hideProcessing();
    }
  });

  function showProcessing() {
    document.getElementById('pay-buttons').style.display = 'none';
    document.getElementById('pay-processing').style.display = 'flex';
  }

  function hideProcessing() {
    document.getElementById('pay-processing').style.display = 'none';
    document.getElementById('pay-buttons').style.display = 'flex';
  }

  function showDone() {
    document.getElementById('done-name').textContent = walkinName.value.trim();
    showStep('done');
    if (searchInput.value.trim()) doSearch();
  }

  document.getElementById('btn-done').addEventListener('click', closeWizard);
</script>

