---
import Base from '@/layouts/Base.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { slug } = Astro.params;

const { data: event } = await supabaseAdmin
  .from('events')
  .select('id, title, door_price')
  .eq('slug', slug!)
  .single();

if (!event) return new Response(null, { status: 404 });

const { count: arrivedCount } = await supabaseAdmin
  .from('rsvps')
  .select('id', { count: 'exact', head: true })
  .eq('event_id', event.id)
  .not('arrived_at', 'is', null);
---

<Base title={`Check-in — ${event.title}`}>
  <main class="checkin-page dark-ctx">
    <header class="checkin-header">
      <h1>{event.title}</h1>
      <span class="arrived-badge" id="arrived-count">{arrivedCount ?? 0} in</span>
    </header>

    <div class="search-wrap">
      <svg class="search-icon" viewBox="0 0 20 20" fill="currentColor" width="18" height="18"
        ><path
          fill-rule="evenodd"
          d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z"
          clip-rule="evenodd"></path></svg
      >
      <input
        type="text"
        id="search-input"
        placeholder="Search name or phone..."
        autofocus
        class="search-input"
      />
    </div>

    <div id="results" class="results"></div>

    <button id="walkin-toggle" class="walkin-toggle">Not on list? Add walk-in</button>

    <div id="walkin-form" class="walkin-form" style="display:none">
      <input type="text" id="walkin-name" placeholder="Guest name" class="walkin-input" />
      <input type="tel" id="walkin-phone" placeholder="Phone (optional)" class="walkin-input" />
      <button id="walkin-submit" class="btn btn-primary">Add & Arrive</button>
    </div>

    <a href={`/door/${slug}/summary`} class="summary-link">View Summary</a>
  </main>
</Base>

<script define:vars={{ slug, doorPrice: event.door_price }}>
  const searchInput = document.getElementById('search-input');
  const results = document.getElementById('results');
  const arrivedCountEl = document.getElementById('arrived-count');
  const walkinToggle = document.getElementById('walkin-toggle');
  const walkinForm = document.getElementById('walkin-form');
  const walkinName = document.getElementById('walkin-name');
  const walkinPhone = document.getElementById('walkin-phone');
  const walkinSubmit = document.getElementById('walkin-submit');

  let debounceTimer;
  let localArrivedCount = parseInt(arrivedCountEl.textContent);

  searchInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doSearch, 150);
  });

  async function doSearch() {
    const q = searchInput.value.trim();
    if (!q) {
      results.innerHTML = '';
      return;
    }

    const res = await fetch(`/api/door/${slug}/search?q=${encodeURIComponent(q)}`);
    const guests = await res.json();

    results.innerHTML = guests
      .map(
        (g) => `
      <div class="guest-card ${g.arrived_at ? 'arrived' : ''}" data-id="${g.id}">
        <div class="guest-info">
          <span class="guest-name">${g.name}</span>
          <span class="guest-phone">${g.phone || ''}</span>
        </div>
        <div class="guest-actions">
          ${
            g.arrived_at
              ? '<span class="guest-badge-arrived">[Arrived]</span>'
              : `<button class="btn btn-primary btn-sm" onclick="markArrived('${g.id}', this)">Mark Arrived</button>`
          }
        </div>
      </div>
    `,
      )
      .join('');
  }

  window.markArrived = async function (rsvpId, btn) {
    btn.disabled = true;
    btn.textContent = '...';
    const res = await fetch(`/api/door/${slug}/arrive`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rsvpId }),
    });
    if (res.ok) {
      const card = btn.closest('.guest-card');
      card.classList.add('arrived');
      btn.outerHTML = '<span class="guest-badge-arrived">[Arrived]</span>';
      localArrivedCount++;
      arrivedCountEl.textContent = localArrivedCount + ' in';
    } else {
      btn.disabled = false;
      btn.textContent = 'Mark Arrived';
    }
  };

  walkinToggle.addEventListener('click', () => {
    walkinForm.style.display = walkinForm.style.display === 'none' ? 'flex' : 'none';
    if (walkinForm.style.display !== 'none') walkinName.focus();
  });

  walkinSubmit.addEventListener('click', async () => {
    const name = walkinName.value.trim();
    if (!name) return;
    walkinSubmit.disabled = true;
    walkinSubmit.textContent = '...';

    const res = await fetch(`/api/door/${slug}/arrive`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, phone: walkinPhone.value.trim() || undefined }),
    });

    if (res.ok) {
      walkinName.value = '';
      walkinPhone.value = '';
      walkinForm.style.display = 'none';
      localArrivedCount++;
      arrivedCountEl.textContent = localArrivedCount + ' in';
      if (searchInput.value.trim()) doSearch();
    }
    walkinSubmit.disabled = false;
    walkinSubmit.textContent = 'Add & Arrive';
  });
</script>

<style>
  .checkin-page {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-md);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    background: var(--color-bg);
    color: var(--color-fg);
  }

  .checkin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-sm);
  }

  .checkin-header h1 {
    font-size: 1.25rem;
    letter-spacing: var(--tracking-tight);
  }

  .arrived-badge {
    border: var(--border-width) solid var(--color-success);
    color: var(--color-success);
    padding: var(--space-xs) var(--space-sm);
    font-weight: var(--weight-medium);
    font-size: 0.875rem;
    letter-spacing: var(--tracking-wide);
  }

  .search-wrap {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    min-height: 48px;
    padding: var(--space-sm) var(--space-sm) var(--space-sm) 42px;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    color: var(--color-fg);
    font-size: 1.0625rem;
    transition: border-color var(--transition);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .results {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
    overflow-y: auto;
  }

  .walkin-toggle {
    background: transparent;
    border: 1px dashed var(--color-border);
    color: var(--color-muted);
    padding: var(--space-sm);
    cursor: pointer;
    font-size: 0.875rem;
    transition:
      border-color var(--transition),
      color var(--transition);
  }

  .walkin-toggle:hover {
    border-color: var(--color-muted);
    color: var(--color-fg);
  }

  .walkin-form {
    display: flex;
    gap: var(--space-sm);
  }

  .walkin-input {
    flex: 1;
    padding: 10px var(--space-sm);
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    color: var(--color-fg);
    font-size: 1rem;
  }

  .walkin-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .summary-link {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.8125rem;
    padding: var(--space-sm);
    text-decoration: none;
    transition: color var(--transition);
  }

  .summary-link:hover {
    color: var(--color-fg);
  }
</style>

<style is:global>
  .guest-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    gap: var(--space-sm);
    transition: border-color 200ms ease;
  }

  .guest-card.arrived {
    border-color: var(--color-success);
  }

  .guest-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .guest-name {
    font-weight: var(--weight-medium);
    font-size: 1.25rem;
  }

  .guest-email {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .guest-phone {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .guest-actions {
    flex-shrink: 0;
  }

  .guest-badge-arrived {
    color: var(--color-success);
    font-weight: var(--weight-medium);
    font-size: 0.8125rem;
    letter-spacing: var(--tracking-wide);
  }
</style>
