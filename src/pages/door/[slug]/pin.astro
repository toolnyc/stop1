---
import Base from '@/layouts/Base.astro';
import { supabaseAdmin } from '@/lib/supabase';

const { slug } = Astro.params;

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { data: event, error } = await supabaseAdmin
  .from('events')
  .select('title')
  .eq('slug', slug!)
  .single();

if (error || !event) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const pinError = Astro.url.searchParams.get('error');
---

<Base title={`Door — ${event.title}`}>
  <main class="pin-page dark-ctx">
    <div class="pin-card">
      <h1>{event.title}</h1>
      <p class="pin-subtitle">[Door PIN]</p>

      {pinError && <div class="alert alert-error">{pinError}</div>}

      <form method="POST" action={`/api/door/${slug}/auth`} class="pin-form">
        <input
          type="text"
          name="pin"
          inputmode="numeric"
          pattern="[0-9]*"
          autocomplete="off"
          required
          autofocus
          class="pin-input"
          placeholder="- - - - - -"
        />
        <button type="submit" class="btn btn-primary btn-block btn-lg">Enter</button>
      </form>
    </div>
  </main>
</Base>

<style>
  .pin-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: var(--space-md);
    background: var(--color-bg);
    color: var(--color-fg);
  }

  .pin-card {
    width: 100%;
    max-width: 320px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .pin-card h1 {
    color: var(--color-accent);
    font-size: 1.5rem;
    letter-spacing: var(--tracking-tight);
  }

  .pin-subtitle {
    color: var(--color-muted);
    margin-top: calc(-1 * var(--space-sm));
    font-size: 0.75rem;
    letter-spacing: var(--tracking-wide);
  }

  .pin-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .pin-input {
    width: 100%;
    min-height: 64px;
    padding: var(--space-md);
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    color: var(--color-fg);
    font-size: 2rem;
    text-align: center;
    letter-spacing: 0.5em;
    transition: border-color var(--transition);
  }

  .pin-input:focus {
    outline: none;
    border-color: var(--color-fg);
  }

  .btn-lg {
    padding: 14px var(--space-lg);
    font-size: 1.0625rem;
  }
</style>
