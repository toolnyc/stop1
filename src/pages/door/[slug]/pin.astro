---
import Base from '@/layouts/Base.astro';
import { supabaseAdmin } from '@/lib/supabase';

const { slug } = Astro.params;

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { data: event, error } = await supabaseAdmin
  .from('events')
  .select('title')
  .eq('slug', slug!)
  .single();

if (error || !event) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const pinError = Astro.url.searchParams.get('error');
---
<Base title={`Door — ${event.title}`}>
  <main class="pin-page">
    <h1>{event.title}</h1>
    <p class="pin-subtitle">Enter Door PIN</p>

    {pinError && <div class="pin-error">{pinError}</div>}

    <form method="POST" action={`/api/door/${slug}/auth`} class="pin-form">
      <input
        type="text"
        name="pin"
        inputmode="numeric"
        pattern="[0-9]*"
        autocomplete="off"
        required
        autofocus
        class="pin-input"
        placeholder="PIN"
      />
      <button type="submit">Enter</button>
    </form>
  </main>
</Base>

<style>
  .pin-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: var(--space-4);
    text-align: center;
  }

  .pin-page h1 {
    color: var(--color-accent);
    font-size: 1.5rem;
    margin-bottom: var(--space-2);
  }

  .pin-subtitle {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .pin-error {
    background: color-mix(in srgb, var(--color-error) 15%, transparent);
    border: 1px solid var(--color-error);
    color: var(--color-error);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    font-size: 0.875rem;
    margin-bottom: var(--space-4);
    width: 100%;
    max-width: 300px;
  }

  .pin-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
    max-width: 300px;
  }

  .pin-input {
    width: 100%;
    min-height: 56px;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    font-size: 2rem;
    text-align: center;
    letter-spacing: 0.5em;
    font-family: var(--font-mono);
  }

  .pin-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  button {
    width: 100%;
    min-height: 48px;
    padding: var(--space-3);
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1.125rem;
    cursor: pointer;
  }

  button:hover { opacity: 0.9; }
</style>
