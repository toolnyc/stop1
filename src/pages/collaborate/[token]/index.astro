---
import Base from '@/layouts/Base.astro';
import { supabaseAdmin } from '@/lib/supabase';
import { createHmac } from 'node:crypto';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { token } = Astro.params;
const cookieSecret = import.meta.env.COOKIE_SECRET;

const { data: collab } = await supabaseAdmin
  .from('collaborators')
  .select('id, event_id, name, accepted_at')
  .eq('invite_token', token!)
  .single();

if (!collab) {
  return Astro.redirect('/');
}

const { data: event } = await supabaseAdmin
  .from('events')
  .select('title, slug')
  .eq('id', collab.event_id)
  .single();

if (!event) {
  return Astro.redirect('/');
}

if (!collab.accepted_at) {
  await supabaseAdmin
    .from('collaborators')
    .update({ accepted_at: new Date().toISOString() })
    .eq('id', collab.id);
}

if (cookieSecret) {
  const payload = Buffer.from(JSON.stringify({ id: collab.id, eventId: collab.event_id })).toString('base64');
  const sig = createHmac('sha256', cookieSecret).update(payload).digest('hex');
  Astro.cookies.set('collab_session', `${payload}.${sig}`, {
    path: '/collaborate',
    httpOnly: true,
    secure: import.meta.env.PROD,
    sameSite: 'strict',
    maxAge: 60 * 60 * 24 * 7,
  });
}
---
<Base title={`Collaborator — ${event.title}`}>
  <main class="invite-page">
    <div class="invite-card">
      <p class="invite-label">[You're invited to]</p>
      <h1>{event.title}</h1>
      <p class="invite-name">as <strong>{collab.name}</strong></p>
      <a href={`/collaborate/${token}/expenses`} class="btn btn-primary">View & Add Expenses</a>
    </div>
  </main>
</Base>

<style>
  .invite-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: var(--space-md);
  }

  .invite-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    max-width: 400px;
  }

  .invite-label {
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-weight: var(--weight-medium);
  }

  .invite-card h1 {
    font-size: 2rem;
    letter-spacing: var(--tracking-tight);
    color: var(--color-accent);
  }

  .invite-name {
    color: var(--color-muted);
    font-size: 1.0625rem;
  }
</style>
