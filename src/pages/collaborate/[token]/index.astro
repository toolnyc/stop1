---
import Base from '@/layouts/Base.astro';
import { supabaseAdmin } from '@/lib/supabase';
import { createHmac } from 'node:crypto';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { token } = Astro.params;
const cookieSecret = import.meta.env.COOKIE_SECRET;

// Look up collaborator by invite token
const { data: collab } = await supabaseAdmin
  .from('collaborators')
  .select('id, event_id, name, accepted_at')
  .eq('invite_token', token!)
  .single();

if (!collab) {
  // Don't return 404 to avoid token enumeration
  return Astro.redirect('/');
}

// Get event info
const { data: event } = await supabaseAdmin
  .from('events')
  .select('title, slug')
  .eq('id', collab.event_id)
  .single();

if (!event) {
  return Astro.redirect('/');
}

// Mark accepted on first visit
if (!collab.accepted_at) {
  await supabaseAdmin
    .from('collaborators')
    .update({ accepted_at: new Date().toISOString() })
    .eq('id', collab.id);
}

// Set collab_session cookie
if (cookieSecret) {
  const payload = Buffer.from(JSON.stringify({ id: collab.id, eventId: collab.event_id })).toString('base64');
  const sig = createHmac('sha256', cookieSecret).update(payload).digest('hex');
  Astro.cookies.set('collab_session', `${payload}.${sig}`, {
    path: '/collaborate',
    httpOnly: true,
    secure: import.meta.env.PROD,
    sameSite: 'strict',
    maxAge: 60 * 60 * 24 * 7, // 7 days
  });
}
---
<Base title={`Collaborator — ${event.title}`}>
  <main class="invite-page">
    <h1>{event.title}</h1>
    <p class="invite-msg">You're invited as <strong>{collab.name}</strong></p>
    <a href={`/collaborate/${token}/expenses`} class="btn-expenses">View & Add Expenses</a>
  </main>
</Base>

<style>
  .invite-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: var(--space-4);
    text-align: center;
    gap: var(--space-4);
  }

  .invite-page h1 {
    color: var(--color-accent);
    font-size: 1.5rem;
  }

  .invite-msg {
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }

  .btn-expenses {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: var(--color-bg);
    text-decoration: none;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
  }

  .btn-expenses:hover { opacity: 0.9; }
</style>
