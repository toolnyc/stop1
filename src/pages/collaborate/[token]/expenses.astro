---
import Base from '@/layouts/Base.astro';
import { supabaseAdmin } from '@/lib/supabase';

if (!supabaseAdmin) {
  return new Response('Server configuration error', { status: 500 });
}

const { token } = Astro.params;
const collaborator = Astro.locals.collaborator;

if (!collaborator) {
  return Astro.redirect(`/collaborate/${token}`);
}

const { data: collab } = await supabaseAdmin
  .from('collaborators')
  .select('name, event_id')
  .eq('id', collaborator.id)
  .single();

if (!collab) return Astro.redirect(`/collaborate/${token}`);

const { data: event } = await supabaseAdmin
  .from('events')
  .select('title')
  .eq('id', collab.event_id)
  .single();

const { data: expenses } = await supabaseAdmin
  .from('expenses')
  .select('*')
  .eq('collaborator_id', collaborator.id)
  .order('created_at', { ascending: false });

const expenseList = expenses ?? [];
const total = expenseList.reduce((sum, e) => sum + Number(e.amount), 0);

const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---
<Base title={`Expenses — ${event?.title ?? 'Event'}`}>
  <main class="expenses-page">
    <h1>{event?.title}</h1>
    <p class="subtitle text-muted">Expenses for {collab.name}</p>

    {error && <div class="alert alert-error">{error}</div>}
    {success && <div class="alert alert-success">{success}</div>}

    <form
      method="POST"
      action="/api/collaborators/expenses/add"
      enctype="multipart/form-data"
      class="add-form card"
    >
      <h2>Add Expense</h2>
      <label>
        <span>Description *</span>
        <input type="text" name="description" required placeholder="e.g. Sound rental" />
      </label>
      <label>
        <span>Amount ($) *</span>
        <input type="number" name="amount" min="0.01" step="0.01" required placeholder="0.00" />
      </label>
      <label>
        <span>Receipt (optional, max 10MB)</span>
        <input type="file" name="receipt" accept="image/*,application/pdf" class="file-input" />
      </label>
      <button type="submit" class="btn btn-primary">Add Expense</button>
    </form>

    <div class="expense-list">
      <h2>Your Expenses <span class="mono text-muted">(${total.toFixed(2)})</span></h2>
      {expenseList.length === 0 ? (
        <p class="empty text-muted">No expenses yet.</p>
      ) : (
        <div class="expense-items">
          {expenseList.map((e) => (
            <div class="expense-row">
              <div class="expense-info">
                <span class="expense-desc">{e.description}</span>
                <span class="expense-date text-muted">{new Date(e.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              </div>
              <div class="expense-actions">
                <span class="expense-amount mono">${Number(e.amount).toFixed(2)}</span>
                {e.receipt_url && (
                  <a href={e.receipt_url} target="_blank" class="receipt-link">Receipt</a>
                )}
                <form method="POST" action="/api/collaborators/expenses/delete" style="display:inline">
                  <input type="hidden" name="expense_id" value={e.id} />
                  <button type="submit" class="btn-icon-delete" title="Delete">&times;</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </main>
</Base>

<style>
  .expenses-page {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  h1 {
    font-size: 1.375rem;
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-xs);
  }

  .subtitle {
    margin-bottom: var(--space-lg);
    font-size: 0.9375rem;
  }

  .alert { margin-bottom: var(--space-md); }

  .add-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-3xl);
  }

  .add-form h2 { font-size: 1.125rem; font-weight: var(--weight-bold); }

  .file-input {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .expense-list h2 {
    font-size: 1.125rem;
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-md);
  }

  .empty { padding: var(--space-md) 0; }

  .expense-items {
    border: var(--border);
    overflow: hidden;
  }

  .expense-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-lg);
    gap: var(--space-sm);
    border-bottom: var(--border);
  }

  .expense-row:last-child { border-bottom: none; }

  .expense-info { display: flex; flex-direction: column; gap: 2px; }
  .expense-desc { font-weight: var(--weight-medium); }
  .expense-date { font-size: 0.75rem; }

  .expense-actions { display: flex; align-items: center; gap: var(--space-sm); flex-shrink: 0; }
  .expense-amount { font-weight: var(--weight-medium); }

  .receipt-link {
    font-size: 0.75rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .btn-icon-delete {
    background: transparent;
    border: var(--border-width) solid var(--color-border);
    color: var(--color-error);
    width: 24px;
    height: 24px;
    cursor: pointer;
    font-size: 0.875rem;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--transition), background var(--transition);
  }

  .btn-icon-delete:hover {
    border-color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 12%, transparent);
  }
</style>
