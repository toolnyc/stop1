{
  "name": "stop1",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/verify-deploy-config.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/database.ts",
    "db:push": "supabase db push",
    "db:new": "supabase migration new",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "test": "vitest run",
    "sync-instructions": "npx ts-node scripts/sync-instructions.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/vercel": "^10.0.4",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/blob": "^2.3.2",
    "astro": "^6.1.3",
    "bcryptjs": "^3.0.3",
    "gsap": "^3.14.2",
    "libphonenumber-js": "^1.12.41",
    "resend": "^6.10.0",
    "stripe": "^21.0.1",
    "tslib": "^2.8.1",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,mjs,astro}": "eslint --fix",
    "*.{ts,mjs,astro,css,json,md}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
