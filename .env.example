# Supabase — https://supabase.com/dashboard/project/_/settings/api
PUBLIC_SUPABASE_URL=              # Project URL (https://xxx.supabase.co)
PUBLIC_SUPABASE_KEY=              # anon/public key
SUPABASE_SECRET_KEY=              # service_role key (server-side only)
SUPABASE_PROJECT_ID=              # Project ref ID (for type generation)

# Auth — used for HMAC-signed session cookies
COOKIE_SECRET=                    # 32+ char random string (openssl rand -hex 32)

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=                # sk_test_... or sk_live_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=    # pk_test_... or pk_live_...
STRIPE_WEBHOOK_SECRET=            # whsec_... (Stripe Dashboard → Developers → Webhooks)

# Resend — https://resend.com/api-keys
RESEND_API_KEY=                   # re_...
EMAIL_FROM=                       # "Stop One <noreply@stop1.party>" (must be verified domain)

# Vercel Blob — https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=            # vercel_blob_rw_...

# Twilio (optional) — https://console.twilio.com
TWILIO_ACCOUNT_SID=               # AC...
TWILIO_AUTH_TOKEN=                 # auth token
TWILIO_FROM_NUMBER=               # +1234567890

# Cron + Alerts
CRON_SECRET=                      # random secret (openssl rand -hex 32) — Vercel sends this on cron requests
DISCORD_WEBHOOK_URL=              # https://discord.com/api/webhooks/...
